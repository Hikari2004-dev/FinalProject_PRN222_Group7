@page
@model FinalProject_PRN222_Group7.Pages.Dashboard.IndexModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="stagger-children">

<!-- Page Header -->
<div class="page-header">
    <div>
        <h1 class="page-title">Xin chào, @Model.UserName</h1>
        <p class="page-subtitle">@DateTime.Now.ToString("dddd, dd MMMM yyyy", new System.Globalization.CultureInfo("vi-VN"))</p>
    </div>
    @if (User.IsInRole("Lecturer") || User.IsInRole("Admin"))
    {
        <a href="/Courses" class="btn btn-primary">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            Môn học & Tài liệu
        </a>
    }
    @if (User.IsInRole("Student"))
    {
        <a href="/Chat" class="btn btn-primary">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
            Hỏi AI ngay
        </a>
    }
</div>

<!-- Stat Cards -->
<div class="stats-grid">
    @if (User.IsInRole("Admin"))
    {
        <div class="stat-card accent">
            <div class="stat-icon accent">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
            </div>
            <div class="stat-value">@Model.Stats.TotalUsers</div>
            <div class="stat-label">Tổng người dùng</div>
        </div>

        <div class="stat-card success">
            <div class="stat-icon success">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14,2 14,8 20,8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
            </div>
            <div class="stat-value">@Model.Stats.TotalDocuments</div>
            <div class="stat-label">Tài liệu đã tải</div>
        </div>

        <div class="stat-card info">
            <div class="stat-icon info">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
            </div>
            <div class="stat-value">@Model.Stats.TotalSessions</div>
            <div class="stat-label">Phiên chat</div>
        </div>

        <div class="stat-card warning">
            <div class="stat-icon warning">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 21V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v16"/></svg>
            </div>
            <div class="stat-value">@Model.Stats.TotalRevenue.ToString("N0") đ</div>
            <div class="stat-label">Doanh thu</div>
        </div>
    }

    @if (User.IsInRole("Lecturer"))
    {
        <div class="stat-card accent">
            <div class="stat-icon accent">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/></svg>
            </div>
            <div class="stat-value">@Model.MyDocumentCount</div>
            <div class="stat-label">Tài liệu đã upload</div>
        </div>
        <div class="stat-card success">
            <div class="stat-icon success">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </div>
            <div class="stat-value">@Model.Stats.IndexedDocuments</div>
            <div class="stat-label">Đã đánh chỉ mục</div>
        </div>
        <div class="stat-card info">
            <div class="stat-icon info">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
            </div>
            <div class="stat-value">@Model.Stats.TotalSessions</div>
            <div class="stat-label">Lượt hỏi AI</div>
        </div>
        <div class="stat-card warning">
            <div class="stat-icon warning">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 015.83 1c0 2-3 3-3 3M12 17h.01"/></svg>
            </div>
            <div class="stat-value">@Model.Stats.TotalQuizAttempts</div>
            <div class="stat-label">Lượt làm quiz</div>
        </div>
    }

    @if (User.IsInRole("Student"))
    {
        <div class="stat-card accent">
            <div class="stat-icon accent">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
            </div>
            <div class="stat-value">@Model.MyChatSessions</div>
            <div class="stat-label">Phiên chat</div>
        </div>
        <div class="stat-card success">
            <div class="stat-icon success">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 015.83 1c0 2-3 3-3 3M12 17h.01"/></svg>
            </div>
            <div class="stat-value">@Model.MyQuizAttempts</div>
            <div class="stat-label">Quiz đã làm</div>
        </div>
        <div class="stat-card info">
            <div class="stat-icon info">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="22,12 18,12 15,21 9,3 6,12 2,12"/></svg>
            </div>
            <div class="stat-value">@Model.MyAvgScore%</div>
            <div class="stat-label">Điểm quiz TB</div>
        </div>
        <div class="stat-card warning">
            <div class="stat-icon warning">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 21V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v16"/></svg>
            </div>
            <div class="stat-value">@(Model.RemainingQueries == int.MaxValue ? "∞" : Model.RemainingQueries.ToString())</div>
            <div class="stat-label">AI credit khả dụng</div>
        </div>
    }
</div>

<!-- Charts + Quick Actions Grid -->
<div style="display:grid;grid-template-columns:2fr 1fr;gap:24px;margin-bottom:24px">

    <!-- Query Chart -->
    <div class="card">
        <div class="card-header">
            <span class="card-title">Lượt hỏi AI - 30 ngày gần nhất</span>
            <span class="badge badge-accent">Chart.js</span>
        </div>
        <div class="card-body">
            <div class="chart-container" style="height:240px">
                <canvas id="queryChart"></canvas>
            </div>
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="card">
        <div class="card-header">
            <span class="card-title">Thao tác nhanh</span>
        </div>
        <div class="card-body" style="display:flex;flex-direction:column;gap:12px">
            <a href="/Chat" class="btn btn-secondary w-full" style="justify-content:flex-start;gap:14px;padding:14px 18px">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
                Hỏi AI mới
            </a>
            <a href="/Quiz" class="btn btn-secondary w-full" style="justify-content:flex-start;gap:14px;padding:14px 18px">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 015.83 1c0 2-3 3-3 3M12 17h.01"/></svg>
                Làm quiz
            </a>
            @if (User.IsInRole("Lecturer") || User.IsInRole("Admin"))
            {
                <a href="/Courses" class="btn btn-secondary w-full" style="justify-content:flex-start;gap:14px;padding:14px 18px">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M4 19.5A2.5 2.5 0 016.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 014 19.5v-15A2.5 2.5 0 016.5 2z"/></svg>
                    Môn học & Tài liệu
                </a>
            }
        </div>
    </div>
</div>

<!-- Recent Activity -->
<div style="display:grid;grid-template-columns:1fr 1fr;gap:24px">
    <div class="card">
        <div class="card-header">
            <span class="card-title">Tài liệu gần đây</span>
            <a href="/Courses" style="font-size:0.85rem;color:var(--accent);font-weight:500">Xem tất cả</a>
        </div>
        <div>
            @if (Model.RecentDocuments.Any())
            {
                @foreach (var doc in Model.RecentDocuments)
                {
                    <div style="display:flex;align-items:center;gap:14px;padding:14px 20px;border-bottom:1px solid var(--border)">
                        <div style="width:42px;height:42px;background:var(--accent-light);border-radius:12px;display:flex;align-items:center;justify-content:center;flex-shrink:0">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14,2 14,8 20,8"/></svg>
                        </div>
                        <div style="flex:1;min-width:0">
                            <div style="font-size:0.875rem;font-weight:600;color:var(--text-primary);white-space:nowrap;overflow:hidden;text-overflow:ellipsis">@doc.OriginalName</div>
                            <div style="font-size:0.75rem;color:var(--text-muted)">@doc.Course.Name | @(doc.UploadedBy?.FullName ?? doc.UploadedByUserEmail)</div>
                        </div>
                        @{
                            var (statusClass, statusText) = doc.Status switch {
                                FinalProject_PRN222_Group7.DAL.Entities.DocumentStatus.Indexed => ("badge-success", "Indexed"),
                                FinalProject_PRN222_Group7.DAL.Entities.DocumentStatus.Processing => ("badge-warning", "Processing"),
                                FinalProject_PRN222_Group7.DAL.Entities.DocumentStatus.Failed => ("badge-danger", "Failed"),
                                _ => ("badge-muted", "Uploaded")
                            };
                        }
                        <span class="badge @statusClass">@statusText</span>
                    </div>
                }
            }
            else
            {
                <div class="empty-state">
                    <div class="empty-icon">📄</div>
                    <div class="empty-title">Chưa có tài liệu</div>
                    <div class="empty-hint">Upload tài liệu đầu tiên để bắt đầu</div>
                </div>
            }
        </div>
    </div>

    <div class="card">
        <div class="card-header">
            <span class="card-title">Chat gần đây</span>
            <a href="/Chat" style="font-size:0.85rem;color:var(--accent);font-weight:500">Xem tất cả</a>
        </div>
        <div>
            @if (Model.RecentSessions.Any())
            {
                @foreach (var s in Model.RecentSessions)
                {
                    <a href="/Chat/Session/@s.Id" style="display:flex;align-items:center;gap:14px;padding:14px 20px;border-bottom:1px solid var(--border);transition:all 0.15s;text-decoration:none" onmouseenter="this.style.background='var(--accent-light)'" onmouseleave="this.style.background='transparent'">
                        <div style="width:42px;height:42px;background:var(--info-light);border-radius:12px;display:flex;align-items:center;justify-content:center;flex-shrink:0">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--info)" stroke-width="2" stroke-linecap="round"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
                        </div>
                        <div style="flex:1;min-width:0">
                            <div style="font-size:0.875rem;font-weight:600;color:var(--text-primary);white-space:nowrap;overflow:hidden;text-overflow:ellipsis">@s.Title</div>
                            <div style="font-size:0.75rem;color:var(--text-muted)">
                                @if (User.IsInRole("Admin") || User.IsInRole("Lecturer"))
                                {
                                    <span style="font-weight:600;color:var(--accent)">@s.User?.FullName</span>
                                    <span> | </span>
                                }
                                @s.UpdatedAt.AddHours(7).ToString("dd/MM HH:mm")
                            </div>
                        </div>
                    </a>
                }
            }
            else
            {
                <div class="empty-state">
                    <div class="empty-icon">💬</div>
                    <div class="empty-title">Chưa có chat</div>
                    <div class="empty-hint">Bắt đầu hỏi AI về tài liệu học tập</div>
                </div>
            }
        </div>
    </div>
</div>

<!-- Analytics & Reports Section -->
<h3 style="font-family:var(--font-sans);font-size:1.1rem;font-weight:700;color:var(--text-primary);margin-top:36px;margin-bottom:16px">Phân tích & Báo cáo học tập</h3>
<div style="display:grid;grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));gap:24px;margin-bottom:24px">
    
    <!-- Donut chart - score distribution -->
    <div class="card">
        <div class="card-header">
            <span class="card-title">Phân bố điểm quiz</span>
        </div>
        <div class="card-body">
            <div class="chart-container" style="height:260px">
                <canvas id="scoreDistChart"></canvas>
            </div>
        </div>
    </div>
    
    <!-- Bar chart - avg score by course -->
    <div class="card">
        <div class="card-header">
            <span class="card-title">Điểm quiz trung bình theo môn</span>
        </div>
        <div class="card-body">
            <div class="chart-container" style="height:260px">
                @if (Model.CourseStats.Any())
                {
                    <canvas id="courseBarChart"></canvas>
                }
                else
                {
                    <div class="empty-state" style="height:100%;display:flex;flex-direction:column;align-items:center;justify-content:center">
                        <div class="empty-icon" style="font-size:2.2rem">📊</div>
                        <div class="empty-title" style="font-size:0.9rem">Chưa có dữ liệu môn học</div>
                    </div>
                }
            </div>
        </div>
    </div>

    @if (User.IsInRole("Admin"))
    {
        <!-- Revenue table -->
        <div class="card">
            <div class="card-header" style="display:flex;align-items:center;justify-content:space-between">
                <span class="card-title">Doanh thu theo gói</span>
                <span style="font-family:var(--font-sans);font-size:1rem;color:var(--success);font-weight:700">@Model.Stats.TotalRevenue.ToString("N0") đ</span>
            </div>
            <div class="table-wrapper" style="overflow-y:auto;max-height:260px">
                <table>
                    <thead>
                        <tr><th>Gói</th><th>Số GD</th><th>Doanh thu</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var r in Model.RevenueByPackage)
                        {
                            <tr>
                                <td class="text-primary">@r.PackageName</td>
                                <td style="font-family:var(--font-mono)">@r.Count</td>
                                <td style="font-family:var(--font-mono);color:var(--success);font-weight:600">@r.Total.ToString("N0") đ</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

</div><!-- end stagger-children -->

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
(function() {
    // 1. Line Chart: Queries
    var labels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ChartLabels));
    var data   = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ChartData));

    var ctx = document.getElementById('queryChart');
    if (ctx) {
        new Chart(ctx, {
            type: 'line',
            data: {
                labels: labels,
                datasets: [{
                    label: 'Lượt hỏi',
                    data: data,
                    borderColor: '#6366f1',
                    backgroundColor: 'rgba(99, 102, 241, 0.1)',
                    borderWidth: 3,
                    pointRadius: 4,
                    pointBackgroundColor: '#6366f1',
                    pointBorderColor: '#fff',
                    pointBorderWidth: 2,
                    tension: 0.4,
                    fill: true
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { 
                    legend: { display: false }, 
                    tooltip: { 
                        mode: 'index',
                        backgroundColor: '#0f172a',
                        titleColor: '#fff',
                        bodyColor: '#94a3b8',
                        borderColor: 'rgba(99, 102, 241, 0.3)',
                        borderWidth: 1,
                        padding: 12,
                        cornerRadius: 8
                    } 
                },
                scales: {
                    x: {
                        grid: { color: 'rgba(148, 163, 184, 0.08)' },
                        ticks: { color: '#64748b', font: { size: 11 }, maxTicksLimit: 8 }
                    },
                    y: {
                        grid: { color: 'rgba(148, 163, 184, 0.08)' },
                        ticks: { color: '#64748b', font: { size: 11 }, stepSize: 1 },
                        beginAtZero: true
                    }
                }
            }
        });
    }

    // 2. Doughnut Chart: Score Distribution
    var scoreData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ScoreDistribution));
    var totalScores = scoreData.reduce((a, b) => a + b, 0);
    var scoreLabels = ['A (>=90)', 'B (>=70)', 'C (>=50)', 'D (<50)'].map(function(label, index) {
        var val = scoreData[index];
        var pct = totalScores > 0 ? Math.round((val / totalScores) * 100) : 0;
        return label + ': ' + val + ' (' + pct + '%)';
    });

    var scoreCtx = document.getElementById('scoreDistChart');
    if (scoreCtx) {
        new Chart(scoreCtx, {
            type: 'doughnut',
            data: {
                labels: scoreLabels,
                datasets: [{
                    data: scoreData,
                    backgroundColor: ['#10b981', '#6366f1', '#f59e0b', '#ef4444'],
                    borderWidth: 0,
                    hoverOffset: 4
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        position: 'bottom',
                        labels: {
                            padding: 12,
                            font: { size: 11, family: "'Inter', sans-serif" },
                            color: '#64748b',
                            usePointStyle: true,
                            pointStyle: 'circle'
                        }
                    },
                    tooltip: {
                        backgroundColor: '#0f172a',
                        titleColor: '#fff',
                        bodyColor: '#94a3b8',
                        borderColor: 'rgba(99, 102, 241, 0.3)',
                        borderWidth: 1,
                        padding: 12,
                        cornerRadius: 8
                    }
                },
                cutout: '65%'
            }
        });
    }

    // 3. Bar Chart: Course Average Quiz Score
    var courseNames = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.CourseStats.Select(s => s.CourseName)));
    var courseScores = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.CourseStats.Select(s => Math.Round(s.AverageScore, 1))));

    var courseCtx = document.getElementById('courseBarChart');
    if (courseCtx && courseNames && courseNames.length > 0) {
        new Chart(courseCtx, {
            type: 'bar',
            data: {
                labels: courseNames,
                datasets: [{
                    label: 'Điểm TB',
                    data: courseScores,
                    backgroundColor: 'rgba(99, 102, 241, 0.8)',
                    borderRadius: 8,
                    borderSkipped: false
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { 
                    legend: { display: false },
                    tooltip: {
                        backgroundColor: '#0f172a',
                        titleColor: '#fff',
                        bodyColor: '#94a3b8',
                        borderColor: 'rgba(99, 102, 241, 0.3)',
                        borderWidth: 1,
                        padding: 12,
                        cornerRadius: 8
                    }
                },
                scales: {
                    x: { 
                        ticks: { color: '#64748b', font: { size: 11 } },
                        grid: { display: false }
                    },
                    y: { 
                        beginAtZero: true, 
                        max: 100, 
                        ticks: { color: '#64748b', font: { size: 11 } },
                        grid: { color: 'rgba(148, 163, 184, 0.08)' }
                    }
                }
            }
        });
    }
})();
</script>
}
