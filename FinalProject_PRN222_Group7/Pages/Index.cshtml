@page
@model IndexModel
@{
    ViewData["Title"] = "Home";
}

@section Styles {
    <link rel="stylesheet" href="~/css/home.css" asp-append-version="true" />
}

<!-- ── Hero ─────────────────────────────────────────────────── -->
<section class="hero-section">
    <div class="container">
        <div class="hero-inner">
            <div class="hero-content animate-fade-up">
                <div class="hero-tag">
                    <span class="hero-tag-dot"></span>
                    AI-Powered Learning
                </div>
                <h1 class="hero-title">
                    Learn smarter with<br />
                    <span class="accent-word">AI assistance</span>
                </h1>
                <p class="hero-sub">
                    EduChat connects students and lecturers through intelligent AI tutoring, course management, and document analysis — all in one platform.
                </p>
                <div class="hero-actions">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <a class="btn btn-primary btn-lg" href="#" id="hero-cta">Go to dashboard</a>
                        <a class="btn btn-outline btn-lg" href="#features" id="hero-features-btn">Explore features</a>
                    }
                    else
                    {
                        <a class="btn btn-primary btn-lg" asp-page="/Auth/Register" id="hero-cta">Start for free</a>
                        <a class="btn btn-outline btn-lg" asp-page="/Auth/Login" id="hero-signin-btn">Sign in</a>
                    }
                </div>
            </div>

            <div class="hero-visual animate-fade-up animate-delay-2">
                <div class="hero-img-wrapper">
                    <img src="https://picsum.photos/seed/edtech-ai-dashboard/800/500"
                         alt="EduChat AI learning platform interface"
                         loading="eager"
                         width="800" height="500" />
                </div>
                <div class="hero-badge">
                    <div class="hero-badge-icon" aria-hidden="true">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.436 60.436 0 00-.491 6.347A48.627 48.627 0 0112 20.904a48.627 48.627 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.57 50.57 0 00-2.658-.813A59.905 59.905 0 0112 3.493a59.902 59.902 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.697 50.697 0 0112 13.489a50.702 50.702 0 017.74-3.342M6.75 15a.75.75 0 100-1.5.75.75 0 000 1.5zm0 0v-3.675A55.378 55.378 0 0112 8.443m-7.007 11.55A5.981 5.981 0 006.75 15.75v-1.5" />
                        </svg>
                    </div>
                    <div class="hero-badge-text">
                        <span class="hero-badge-val">500+</span>
                        <span class="hero-badge-label">Active learners</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ── Stats ─────────────────────────────────────────────────── -->
<section class="stats-section" aria-label="Platform statistics">
    <div class="container">
        <div class="stats-grid">
            <div class="stat-item reveal">
                <div class="stat-value">10<span>k+</span></div>
                <div class="stat-label">Study sessions</div>
            </div>
            <div class="stat-item reveal" style="transition-delay:0.1s">
                <div class="stat-value">250<span>+</span></div>
                <div class="stat-label">Courses available</div>
            </div>
            <div class="stat-item reveal" style="transition-delay:0.2s">
                <div class="stat-value">98<span>%</span></div>
                <div class="stat-label">Satisfaction rate</div>
            </div>
            <div class="stat-item reveal" style="transition-delay:0.3s">
                <div class="stat-value">24<span>/7</span></div>
                <div class="stat-label">AI tutor availability</div>
            </div>
        </div>
    </div>
</section>

<!-- ── Features ─────────────────────────────────────────────── -->
<section class="features-section" id="features" aria-labelledby="features-heading">
    <div class="container">
        <div class="section-header">
            <h2 class="section-title" id="features-heading">Everything you need to learn</h2>
            <p class="section-sub">Built for students who want deeper understanding and lecturers who want better insights.</p>
        </div>

        <div class="features-grid">
            <!-- Featured card -->
            <div class="feature-card featured reveal">
                <div class="feature-icon" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M8.625 12a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H8.25m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H12m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 01-2.555-.337A5.972 5.972 0 015.41 20.97a5.969 5.969 0 01-.474-.065 4.48 4.48 0 00.978-2.025c.09-.457-.133-.901-.467-1.226C3.93 16.178 3 14.189 3 12c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25z"/>
                    </svg>
                </div>
                <h3 class="feature-title">AI Chat Tutor</h3>
                <p class="feature-desc">Ask questions in natural language and get instant, contextual answers based on your course materials. Your AI tutor learns what you need.</p>
            </div>

            <!-- Card 2 -->
            <div class="feature-card reveal" style="transition-delay:0.1s">
                <div class="feature-icon" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/>
                    </svg>
                </div>
                <h3 class="feature-title">Document Analysis</h3>
                <p class="feature-desc">Upload PDFs, slides, and notes. AI extracts key concepts and generates summaries instantly.</p>
            </div>

            <!-- Card 3 -->
            <div class="feature-card reveal" style="transition-delay:0.15s">
                <div class="feature-icon" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.436 60.436 0 00-.491 6.347A48.627 48.627 0 0112 20.904a48.627 48.627 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.57 50.57 0 00-2.658-.813A59.905 59.905 0 0112 3.493a59.902 59.902 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.697 50.697 0 0112 13.489a50.702 50.702 0 017.74-3.342M6.75 15a.75.75 0 100-1.5.75.75 0 000 1.5zm0 0v-3.675A55.378 55.378 0 0112 8.443m-7.007 11.55A5.981 5.981 0 006.75 15.75v-1.5"/>
                    </svg>
                </div>
                <h3 class="feature-title">Course Management</h3>
                <p class="feature-desc">Lecturers can organize courses, track student progress, and get AI-generated teaching insights.</p>
            </div>

            <!-- Card 4 -->
            <div class="feature-card reveal" style="transition-delay:0.2s">
                <div class="feature-icon" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3v11.25A2.25 2.25 0 006 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0118 16.5h-2.25m-7.5 0h7.5m-7.5 0l-1 3m8.5-3l1 3m0 0l.5 1.5m-.5-1.5h-9.5m0 0l-.5 1.5m.75-9 3-3 2.148 2.148A12.061 12.061 0 0116.5 7.605"/>
                    </svg>
                </div>
                <h3 class="feature-title">Progress Analytics</h3>
                <p class="feature-desc">Visual dashboards show learning patterns, time spent, and mastery levels across all subjects.</p>
            </div>
        </div>
    </div>
</section>

<!-- ── How It Works ─────────────────────────────────────────── -->
<section class="how-section" id="how-it-works" aria-labelledby="how-heading">
    <div class="container">
        <div class="section-header">
            <h2 class="section-title" id="how-heading">Up and running in minutes</h2>
            <p class="section-sub">No complex setup. Just sign up, join your courses, and start learning with AI.</p>
        </div>
        <div class="steps-grid">
            <div class="step-item reveal">
                <div class="step-connector" aria-hidden="true"></div>
                <div class="step-num" aria-hidden="true">01</div>
                <h3 class="step-title">Create your account</h3>
                <p class="step-desc">Register as a student or lecturer. Secure, takes under 30 seconds.</p>
            </div>
            <div class="step-item reveal" style="transition-delay:0.12s">
                <div class="step-connector" aria-hidden="true"></div>
                <div class="step-num" aria-hidden="true">02</div>
                <h3 class="step-title">Join or create courses</h3>
                <p class="step-desc">Students enroll in available courses. Lecturers upload documents and materials.</p>
            </div>
            <div class="step-item reveal" style="transition-delay:0.24s">
                <div class="step-num" aria-hidden="true">03</div>
                <h3 class="step-title">Learn with AI</h3>
                <p class="step-desc">Chat with your AI tutor, get instant answers, and track your progress in real time.</p>
            </div>
        </div>
    </div>
</section>

<!-- ── CTA ─────────────────────────────────────────────────── -->
<section class="cta-section">
    <div class="container">
        <div class="cta-card reveal">
            <h2 class="cta-title">Ready to learn smarter?</h2>
            <p class="cta-sub">Join thousands of students and lecturers already using EduChat to accelerate learning.</p>
            @if (User.Identity?.IsAuthenticated == true)
            {
                <a class="btn btn-primary btn-lg" href="#" id="cta-dashboard-btn">Go to dashboard</a>
            }
            else
            {
                <a class="btn btn-primary btn-lg" asp-page="/Auth/Register" id="cta-signup-btn">Get started free</a>
            }
        </div>
    </div>
</section>
