@page
@model ForgotPasswordModel
@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Quên mật khẩu";
}

<div class="auth-page">
    <!-- Left Panel -->
    <div class="auth-left">
        <div style="position:relative;z-index:1">
            <div style="display:flex;align-items:center;gap:12px;margin-bottom:56px">
                <div style="width:38px;height:38px;background:var(--accent);border-radius:8px;display:flex;align-items:center;justify-content:center;box-shadow:var(--shadow-accent)">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round">
                        <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
                    </svg>
                </div>
                <span style="font-size:1.1rem;font-weight:700;color:var(--text-primary)">LMS AI Platform</span>
            </div>

            <h1 style="font-size:2.4rem;font-weight:800;letter-spacing:-0.03em;color:var(--text-primary);line-height:1.2;margin-bottom:16px">
                Đặt lại mật khẩu<br>đơn giản & an toàn
            </h1>
            <p style="font-size:1rem;color:var(--text-secondary);line-height:1.65;max-width:340px;margin-bottom:40px">
                Nhập địa chỉ email đăng ký của bạn để nhận liên kết xác thực đặt lại mật khẩu mới.
            </p>
        </div>
    </div>

    <!-- Right Panel -->
    <div class="auth-right">
        <div class="auth-form-box slide-up">
            <h2 class="auth-title">Quên mật khẩu?</h2>
            <p class="auth-subtitle">Nhập email để nhận liên kết đặt lại mật khẩu</p>

            @if (Model.SuccessMessage != null)
            {
                <div style="background:var(--success-muted);border:1px solid rgba(16,185,129,0.25);border-radius:var(--radius);padding:12px 14px;margin-bottom:20px;font-size:0.875rem;color:var(--success)">
                    @Model.SuccessMessage
                </div>
            }

            @if (Model.ErrorMessage != null)
            {
                <div style="background:var(--danger-muted);border:1px solid rgba(239,68,68,0.25);border-radius:var(--radius);padding:12px 14px;margin-bottom:20px;font-size:0.875rem;color:var(--danger)">
                    @Model.ErrorMessage
                </div>
            }

            <form method="post">
                @Html.AntiForgeryToken()

                <div style="display:flex;flex-direction:column;gap:16px;margin-bottom:24px">
                    <div class="form-group">
                        <label class="form-label" for="email">Email đăng ký</label>
                        <input id="email" type="email" name="Email" class="form-control"
                               placeholder="ten@@truong.edu.vn" value="@Model.Email" autocomplete="email" required />
                    </div>
                </div>

                <button type="submit" class="btn btn-primary w-full btn-lg" style="margin-bottom:16px">
                    Gửi liên kết đặt lại
                </button>

                <div style="text-align:center;font-size:0.875rem;color:var(--text-secondary)">
                    Quay lại <a href="/Auth/Login" style="color:var(--accent);text-decoration:none;font-weight:600">Đăng nhập</a>
                </div>
            </form>
        </div>
    </div>
</div>
