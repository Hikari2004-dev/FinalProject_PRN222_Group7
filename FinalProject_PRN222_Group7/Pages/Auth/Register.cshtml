@page
@model FinalProject_PRN222_Group7.Pages.Auth.RegisterModel
@{
    ViewData["Title"] = "Create Account";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Create a free EduChat account — AI-powered learning platform" />
    <title>Create Account — EduChat</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
</head>
<body>
<div class="auth-page">
    <!-- ── Left decorative panel ─────────────────────────────── -->
    <div class="auth-panel-left" aria-hidden="true">
        <div class="auth-grid-overlay"></div>

        <div class="auth-panel-brand">
            <a class="auth-brand-link" href="/">
                <div class="auth-brand-logo">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M11.7 2.805a.75.75 0 01.6 0A60.65 60.65 0 0122.83 8.72a.75.75 0 01-.231 1.337 49.949 49.949 0 00-9.902 3.912l-.003.002-.34.18a.75.75 0 01-.707 0A50.009 50.009 0 007.5 12.174v-.224c0-.131.067-.248.172-.311a54.614 54.614 0 014.653-2.52.75.75 0 00-.65-1.352 56.129 56.129 0 00-4.78 2.589 1.858 1.858 0 00-.859 1.228 49.803 49.803 0 00-4.634-1.527.75.75 0 01-.231-1.337A60.653 60.653 0 0111.7 2.805z"/>
                        <path d="M13.06 15.473a48.45 48.45 0 017.666-3.282c.134 1.414.22 2.843.255 4.285a.75.75 0 01-.46.71 47.878 47.878 0 00-8.105 4.342.75.75 0 01-.832 0 47.205 47.205 0 00-1.346-.808c-.169-.1-.198-.303-.064-.448A48.297 48.297 0 0013.06 15.47z"/>
                    </svg>
                </div>
                EduChat
            </a>
        </div>

        <div class="auth-panel-content">
            <p class="auth-panel-quote">
                Start your <span class="highlight">AI-powered</span><br />
                learning journey today
            </p>
            <p class="auth-panel-desc">
                Join students and lecturers who are already using EduChat to study smarter and teach more effectively.
            </p>
            <div class="auth-panel-features">
                <div class="auth-panel-feature">
                    <span class="auth-panel-feature-dot"></span>
                    Free to get started, no credit card needed
                </div>
                <div class="auth-panel-feature">
                    <span class="auth-panel-feature-dot"></span>
                    Student and lecturer accounts supported
                </div>
                <div class="auth-panel-feature">
                    <span class="auth-panel-feature-dot"></span>
                    AI tutor trained on your course content
                </div>
            </div>
        </div>

        <p class="auth-panel-footer">&copy; 2026 EduChat &mdash; Group 7, PRN222</p>
    </div>

    <!-- ── Right form panel ──────────────────────────────────── -->
    <div class="auth-panel-right">
        <div class="auth-form-wrapper">
            <div class="auth-form-header">
                <h1 class="auth-form-title">Create your account</h1>
                <p class="auth-form-sub">Start learning with AI-powered assistance</p>
            </div>

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="auth-alert auth-alert-error" role="alert">
                    <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
                        <circle cx="12" cy="12" r="10"/>
                        <line x1="15" y1="9" x2="9" y2="15"/>
                        <line x1="9" y1="9" x2="15" y2="15"/>
                    </svg>
                    <span>@Model.ErrorMessage</span>
                </div>
            }

            <form method="post" novalidate>
                <div class="auth-form-group">
                    <label class="auth-label" for="fullname">Full Name</label>
                    <input id="fullname"
                           type="text"
                           asp-for="Input.FullName"
                           class="auth-input"
                           placeholder="Nguyen Van A"
                           required
                           autocomplete="name" />
                </div>

                <div class="auth-form-group">
                    <label class="auth-label" for="email">Email</label>
                    <input id="email"
                           type="email"
                           asp-for="Input.Email"
                           class="auth-input"
                           placeholder="you@example.com"
                           required
                           autocomplete="email" />
                </div>

                <div class="auth-form-group">
                    <label class="auth-label" for="password">Password</label>
                    <div class="auth-password-wrapper">
                        <input id="password"
                               type="password"
                               asp-for="Input.Password"
                               class="auth-input"
                               placeholder="At least 6 characters"
                               required
                               autocomplete="new-password" />
                        <button type="button" class="auth-password-toggle" id="pw-toggle" aria-label="Toggle password visibility">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" aria-hidden="true">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z"/>
                                <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                            </svg>
                        </button>
                    </div>
                </div>

                <div class="auth-form-group">
                    <label class="auth-label" for="confirmpassword">Confirm Password</label>
                    <input id="confirmpassword"
                           type="password"
                           asp-for="Input.ConfirmPassword"
                           class="auth-input"
                           placeholder="Re-enter your password"
                           required
                           autocomplete="new-password" />
                </div>

                <div class="auth-form-group">
                    <label class="auth-label" for="role">I am a</label>
                    <select id="role" asp-for="Input.Role" class="auth-select">
                        <option value="2">Student</option>
                        <option value="1">Lecturer</option>
                    </select>
                </div>

                <button type="submit" class="auth-submit" id="register-submit-btn">Create account</button>
            </form>

            <div class="auth-form-footer">
                Already have an account? <a asp-page="/Auth/Login">Sign in</a>
            </div>
        </div>
    </div>
</div>

<script>
    (function () {
        const toggle = document.getElementById('pw-toggle');
        const input  = document.getElementById('password');
        if (!toggle || !input) return;
        toggle.addEventListener('click', function () {
            const isPassword = input.type === 'password';
            input.type = isPassword ? 'text' : 'password';
            toggle.setAttribute('aria-label', isPassword ? 'Hide password' : 'Toggle password visibility');
        });
    })();
</script>
</body>
</html>
