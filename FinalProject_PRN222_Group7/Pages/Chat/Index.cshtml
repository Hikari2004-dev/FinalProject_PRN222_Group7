@page
@model FinalProject_PRN222_Group7.Pages.Chat.IndexModel
@{
    ViewData["Title"] = "AI Chatbot";
}

@section Styles {
    <style>
        .page-content {
            padding: 0;
        }

        .chat-layout {
            min-height: calc(100vh - var(--topbar-h));
        }

        .message-bubble p {
            margin-bottom: 10px;
            line-height: 1.7;
        }

        .message-bubble p:last-child {
            margin-bottom: 0;
        }

        .message-bubble ul, .message-bubble ol {
            margin-left: 20px;
            margin-bottom: 10px;
            padding-left: 0;
        }

        .message-bubble li {
            margin-bottom: 6px;
            line-height: 1.6;
        }

        .message-bubble h1, .message-bubble h2, .message-bubble h3, .message-bubble h4 {
            font-size: 1rem;
            font-weight: 700;
            margin-top: 14px;
            margin-bottom: 8px;
            color: var(--text-primary);
        }
        
        .message-bubble code {
            background: var(--bg-elevated);
            padding: 2px 6px;
            border-radius: 4px;
            font-family: 'SF Mono', 'Fira Code', monospace;
            font-size: 0.85em;
        }
        
        .message-bubble pre {
            background: var(--bg-elevated);
            padding: 14px;
            border-radius: var(--radius);
            overflow-x: auto;
            margin: 10px 0;
        }
        
        .message-bubble pre code {
            background: none;
            padding: 0;
        }

        .typing-bubble {
            padding: 12px 18px !important;
            background: rgba(139, 92, 246, 0.08) !important;
            border: 1px solid rgba(139, 92, 246, 0.25) !important;
            border-radius: 16px !important;
        }

        .ai-thinking-box {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .ai-thinking-dots {
            display: flex;
            align-items: center;
            gap: 4px;
        }

        .ai-thinking-dots span {
            width: 7px;
            height: 7px;
            background: #8b5cf6;
            border-radius: 50%;
            display: inline-block;
            animation: thinkingBounce 1.4s infinite ease-in-out both;
        }

        .ai-thinking-dots span:nth-child(1) { animation-delay: -0.32s; }
        .ai-thinking-dots span:nth-child(2) { animation-delay: -0.16s; }

        @@keyframes thinkingBounce {
            0%, 80%, 100% { transform: scale(0.4); opacity: 0.4; }
            40% { transform: scale(1.15); opacity: 1; }
        }

        .ai-thinking-text {
            font-size: 0.85rem;
            color: var(--text-secondary);
            font-weight: 500;
        }

        .citation-pill.citation-link {
            background: rgba(59, 130, 246, 0.12);
            color: #3b82f6;
            border: 1px solid rgba(59, 130, 246, 0.25);
            transition: all 0.2s ease;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 4px;
        }

        .citation-pill.citation-link:hover {
            background: rgba(59, 130, 246, 0.25);
            border-color: #3b82f6;
            transform: translateY(-1px);
            box-shadow: 0 2px 8px rgba(59, 130, 246, 0.2);
        }

        .inline-cite-tag {
            display: inline-flex;
            align-items: center;
            gap: 2px;
            font-size: 0.72rem;
            font-weight: 600;
            line-height: 1;
            padding: 2px 7px;
            margin: 0 3px;
            border-radius: 4px;
            background: rgba(139, 92, 246, 0.12);
            color: #8b5cf6;
            border: 1px solid rgba(139, 92, 246, 0.25);
            text-decoration: none !important;
            vertical-align: super;
            transition: all 0.15s ease;
        }

        .inline-cite-tag:hover {
            background: #8b5cf6;
            color: #ffffff;
            border-color: #8b5cf6;
            transform: translateY(-1px);
            box-shadow: 0 2px 6px rgba(139, 92, 246, 0.3);
        }
    </style>
}

<div class="chat-layout">
    <!-- Chat Sidebar -->
    <div class="chat-sidebar">
        <div class="chat-sidebar-header">
            <button onclick="newChat()" class="btn btn-primary w-full btn-sm" style="height:40px">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                Chat mới
            </button>
            <div style="margin-top:12px">
                <input type="text" id="searchSessions" class="form-control" placeholder="Tìm kiếm chat..." style="font-size:0.85rem;padding:10px 14px" oninput="filterSessions(this.value)" />
            </div>
        </div>

        <div class="chat-sessions" id="sessionsList">
            @if (Model.Sessions.Any())
            {
                @foreach (var s in Model.Sessions)
                {
                    <div class="chat-session-item @(s.Id == Model.ActiveSessionId ? "active" : "")"
                         onclick="loadSession(@s.Id)"
                         data-title="@s.Title.ToLower()"
                         style="position:relative;display:flex;justify-content:space-between;align-items:center;padding:12px 14px;border-radius:var(--radius)">
                        <div>
                            <div class="chat-session-title">@s.Title</div>
                            <div class="chat-session-time">@s.UpdatedAt.ToString("dd/MM HH:mm")</div>
                        </div>
                        <button type="button" onclick="deleteSession(@s.Id, '@Html.Raw(s.Title.Replace("'", "\\'"))', event)" style="position:absolute;right:8px;top:50%;transform:translateY(-50%);background:none;border:none;color:var(--text-muted);cursor:pointer;padding:6px;display:flex;align-items:center;justify-content:center;border-radius:var(--radius);transition:all 0.15s" onmouseover="this.style.background='var(--danger-light)';this.style.color='var(--danger)'" onmouseout="this.style.background='none';this.style.color='var(--text-muted)'" title="Xóa lịch sử chat">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                        </button>
                    </div>
                }
            }
            else
            {
                <div style="padding:24px;text-align:center;font-size:0.85rem;color:var(--text-muted)">Chưa có cuộc trò chuyện nào</div>
            }
        </div>
    </div>

    <!-- Chat Main -->
    <div class="chat-main">
        <!-- Chat Header -->
        <div style="padding:16px 24px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:14px;background:var(--bg-surface)">
            <div style="width:40px;height:40px;background:var(--gradient-primary);border-radius:12px;display:flex;align-items:center;justify-content:center;box-shadow:var(--shadow-accent)">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
            </div>
            <div>
                <div style="font-family:var(--font-sans);font-weight:700;font-size:1rem" id="chatTitle">@(Model.ActiveSession?.Title ?? "AI Chatbot")</div>
                <div style="font-size:0.75rem;color:var(--success);display:flex;align-items:center;gap:6px;margin-top:2px">
                    <span style="width:8px;height:8px;background:var(--success);border-radius:50%;display:inline-block;box-shadow:0 0 6px var(--success)"></span>
                    Sẵn sàng trả lời
                </div>
            </div>

            <div style="margin-left:auto;display:flex;align-items:center;gap:12px">
                <select id="courseSelector" class="form-control" style="width:180px;font-size:0.85rem;padding:10px 14px" @(Model.ActiveSessionId.HasValue ? "disabled" : "")>
                    <option value="">-- Chọn môn học --</option>
                    @foreach (var c in Model.Courses)
                    {
                        <option value="@c.Id" selected="@(Model.ActiveSession?.CourseId == c.Id)">@c.Name</option>
                    }
                </select>
            </div>
        </div>

        <!-- Messages Area -->
        <div class="chat-messages" id="messagesArea">
            @if (Model.ActiveSession == null || !Model.ActiveSession.Messages.Any())
            {
                <div id="welcomeState" style="flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;gap:20px">
                    <div style="width:80px;height:80px;background:var(--gradient-primary);border-radius:20px;display:flex;align-items:center;justify-content:center;box-shadow:var(--shadow-glow)">
                        <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
                    </div>
                    <div>
                        <h2 style="font-family:var(--font-sans);font-size:1.4rem;font-weight:800;color:var(--text-primary);margin-bottom:8px">Xin chào! Tôi là AI học tập</h2>
                        <p style="font-size:0.95rem;color:var(--text-secondary);max-width:360px">Tôi sẽ trả lời câu hỏi dựa trên tài liệu học tập của bạn. Hãy chọn môn học và bắt đầu hỏi!</p>
                    </div>
                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;max-width:440px;width:100%">
                        @foreach (var q in new[] { "Tóm tắt nội dung chương 1?", "Giải thích khái niệm X?", "Cho ví dụ về Y?", "So sánh A và B?" })
                        {
                            <button onclick="document.getElementById('chatInput').value='@q';document.getElementById('chatInput').focus()"
                                    style="padding:12px 16px;background:var(--bg-surface);border:1px solid var(--border);border-radius:var(--radius-lg);text-align:left;cursor:pointer;font-size:0.85rem;color:var(--text-secondary);transition:all 0.15s;font-family:var(--font-body)"
                                    onmouseenter="this.style.borderColor='var(--accent)';this.style.background='var(--accent-light)';this.style.color='var(--accent)'"
                                    onmouseleave="this.style.borderColor='var(--border)';this.style.background='var(--bg-surface)';this.style.color='var(--text-secondary)'">
                                @q
                            </button>
                        }
                    </div>
                </div>
            }
            else
            {
                @foreach (var msg in Model.ActiveSession.Messages)
                {
                    <div class="message @(msg.Role == FinalProject_PRN222_Group7.DAL.Entities.MessageRole.User ? "user" : "")">
                        <div class="message-avatar">
                            @(msg.Role == FinalProject_PRN222_Group7.DAL.Entities.MessageRole.User ? Model.UserInitials : "AI")
                        </div>
                        <div>
                            <div class="message-bubble">@msg.Content</div>
                            @if (msg.SourceCitations != null)
                            {
                                <div class="message-citations">
                                    <span style="font-size:0.75rem;color:var(--text-muted);font-weight:500">Nguồn:</span>
                                    @foreach (var cite in msg.SourceCitations.Split(',', StringSplitOptions.RemoveEmptyEntries))
                                    {
                                        var parts = cite.Split('|');
                                        var label = parts[0].Trim();
                                        var link = parts.Length > 1 ? parts[1].Trim() : null;
                                        if (!string.IsNullOrEmpty(link))
                                        {
                                            <a href="@link" target="_blank" class="citation-pill citation-link" style="text-decoration:none">📄 @label ↗</a>
                                        }
                                        else
                                        {
                                            <span class="citation-pill">@label</span>
                                        }
                                    }
                                </div>
                            }
                        </div>
                    </div>
                }
            }
        </div>

        <!-- Chat Input -->
        <div class="chat-input-area">
            <div class="chat-input-wrapper" id="inputWrapper">
                <textarea id="chatInput" class="chat-textarea" data-autoresize
                          placeholder="Nhập câu hỏi về tài liệu..."
                          rows="1"
                          onkeydown="handleKeyDown(event)"></textarea>
                <button id="sendBtn" class="chat-send-btn" onclick="sendMessage()" title="Gửi (Enter)">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
                </button>
            </div>
            <div class="chat-meta">
                <span>Enter để gửi, Shift+Enter xuống dòng</span>
                <span class="queries-remaining">Còn @(Model.RemainingQueries == int.MaxValue ? "vô hạn" : Model.RemainingQueries + " AI credit")</span>
            </div>
        </div>
    </div>
</div>

@Html.AntiForgeryToken()

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
    <script>
        var activeSessionId = @(Model.ActiveSessionId?.ToString() ?? "null");
        var antiForgeryToken = document.querySelector('input[name="__RequestVerificationToken"]')?.value;

        // Configure marked
        if (typeof marked !== 'undefined') {
            marked.setOptions({
                breaks: true,
                gfm: true
            });
        }

        function newChat() {
            activeSessionId = null;
            document.getElementById('chatTitle').textContent = 'AI Chatbot';
            var selector = document.getElementById('courseSelector');
            if (selector) {
                selector.value = "";
                selector.removeAttribute('disabled');
            }
            var area = document.getElementById('messagesArea');
            area.innerHTML = '<div style="flex:1;display:flex;align-items:center;justify-content:center;color:var(--text-muted);font-size:0.9rem">Bắt đầu cuộc trò chuyện mới...</div>';
            document.querySelectorAll('.chat-session-item').forEach(el => el.classList.remove('active'));
        }

        function loadSession(id) {
            window.location.href = '/Chat/Session/' + id;
        }

        function filterSessions(val) {
            document.querySelectorAll('.chat-session-item').forEach(function(el) {
                el.style.display = el.dataset.title.includes(val.toLowerCase()) ? '' : 'none';
            });
        }

        function handleKeyDown(e) {
            if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendMessage(); }
            var ta = document.getElementById('chatInput');
            setTimeout(function() {
                ta.style.height = 'auto';
                ta.style.height = Math.min(ta.scrollHeight, 160) + 'px';
            }, 0);
        }

        async function sendMessage() {
            var courseId = document.getElementById('courseSelector').value;
            if (!courseId) {
                showAlert('Chưa chọn môn học', 'Vui lòng chọn môn học trước khi bắt đầu chat!', '⚠️');
                return;
            }

            var input = document.getElementById('chatInput');
            var msg = input.value.trim();
            if (!msg) return;

            window.latestQuestionText = msg;

            var area = document.getElementById('messagesArea');
            var welcome = document.getElementById('welcomeState');
            if (welcome) welcome.remove();

            appendMessage('user', msg, null);
            input.value = '';
            input.style.height = 'auto';

            var typingDiv = document.createElement('div');
            typingDiv.className = 'message';
            typingDiv.id = 'typingIndicator';
            typingDiv.innerHTML = '<div class="message-avatar">AI</div><div class="message-bubble typing-bubble"><div class="ai-thinking-box"><div class="ai-thinking-dots"><span></span><span></span><span></span></div><span class="ai-thinking-text">AI đang đọc tài liệu và suy nghĩ trả lời...</span></div></div>';
            area.appendChild(typingDiv);
            area.scrollTop = area.scrollHeight;

            try {
                var courseId = document.getElementById('courseSelector').value;
                var res = await fetch('/api/chat/send', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': antiForgeryToken },
                    body: JSON.stringify({ question: msg, sessionId: activeSessionId, courseId: courseId || null })
                });
                var data = await res.json();

                typingDiv.remove();

                if (data.sessionId) {
                    activeSessionId = data.sessionId;
                    var selector = document.getElementById('courseSelector');
                    if (selector) {
                        selector.setAttribute('disabled', 'disabled');
                    }
                }
                appendMessage('ai', data.answer, data.citations);
            } catch (err) {
                typingDiv.remove();
                appendMessage('ai', 'Xin lỗi, đã có lỗi xảy ra. Vui lòng thử lại.', null);
            }
        }

        function formatInlineCitations(text) {
            if (!text) return '';
            return text.replace(/\[Chunk\s*#?(\d+)(?:\|(\d+))?(?:\|quote:\s*([^\]]+))?\]/gi, function(match, chunkNum, docId, quoteText) {
                var cleanQuote = quoteText ? quoteText.trim() : '';
                var paramStr = cleanQuote ? '?quote=' + encodeURIComponent(cleanQuote) : (window.latestQuestionText ? '?q=' + encodeURIComponent(window.latestQuestionText) : '');
                var href = docId ? '/Documents/Detail/' + docId + paramStr + '#chunk-' + chunkNum : '#';
                var titleText = cleanQuote ? 'Trích dẫn: "' + escapeHtml(cleanQuote) + '"' : 'Xem phân mảnh Chunk #' + chunkNum;
                return '<a href="' + href + '" target="_blank" class="inline-cite-tag" title="' + titleText + '">Chunk #' + chunkNum + ' ↗</a>';
            });
        }

        document.addEventListener('DOMContentLoaded', function() {
            document.querySelectorAll('.message:not(.user) .message-bubble').forEach(function(el) {
                el.innerHTML = formatInlineCitations(el.innerHTML);
            });
        });

        function appendMessage(role, content, citations) {
            var area = document.getElementById('messagesArea');
            var div = document.createElement('div');
            div.className = 'message' + (role === 'user' ? ' user' : '');

            var avatarText = role === 'user' ? '@Model.UserInitials' : 'AI';
            var citeHtml = '';
            if (citations && citations.length > 0) {
                citeHtml = '<div class="message-citations"><span style="font-size:0.75rem;color:var(--text-muted);font-weight:500">Nguồn:</span>';
                var qParam = window.latestQuestionText ? '?q=' + encodeURIComponent(window.latestQuestionText) : '';
                citations.forEach(function(c) {
                    var parts = c.split('|');
                    var label = parts[0].trim();
                    var link = parts.length > 1 ? parts[1].trim() : null;
                    if (link) {
                        var fullLink = link + (link.includes('?') ? '&q=' + encodeURIComponent(window.latestQuestionText || '') : qParam);
                        citeHtml += '<a href="' + fullLink + '" target="_blank" class="citation-pill citation-link" style="text-decoration:none">📄 ' + escapeHtml(label) + ' ↗</a>';
                    } else {
                        citeHtml += '<span class="citation-pill">' + escapeHtml(label) + '</span>';
                    }
                });
                citeHtml += '</div>';
            }

            var rawRendered = role === 'user' ? escapeHtml(content) : (typeof marked !== 'undefined' ? marked.parse(content) : content);
            var renderedContent = role === 'user' ? rawRendered : formatInlineCitations(rawRendered);
            div.innerHTML = '<div class="message-avatar">' + avatarText + '</div><div><div class="message-bubble">' + renderedContent + '</div>' + citeHtml + '</div>';
            area.appendChild(div);
            area.scrollTop = area.scrollHeight;
        }

        function escapeHtml(t) {
            var d = document.createElement('div');
            d.appendChild(document.createTextNode(t));
            return d.innerHTML;
        }

        function deleteSession(sessionId, title, event) {
            if (event) event.stopPropagation();

            showConfirm(
                'Xóa lịch sử trò chuyện',
                `Bạn có chắc chắn muốn xóa lịch sử trò chuyện "${title}" không? Hành động này sẽ xóa toàn bộ nội dung trò chuyện và không thể phục hồi!`,
                '🗑️',
                () => {
                    const formData = new FormData();
                    formData.append('sessionId', sessionId);

                    fetch('?handler=DeleteSession', {
                        method: 'POST',
                        body: formData,
                        headers: {
                            'RequestVerificationToken': antiForgeryToken
                        }
                    })
                    .then(res => res.json())
                    .then(data => {
                        if (data.success) {
                            showAlert('Đã xóa', 'Lịch sử cuộc trò chuyện đã được xóa thành công.', '✅', () => {
                                window.location.href = '/Chat';
                            });
                        } else {
                            showAlert('Lỗi', data.error || 'Không thể xóa cuộc trò chuyện.', '❌');
                        }
                    })
                    .catch(err => {
                        showAlert('Lỗi kết nối', 'Không thể kết nối với hệ thống để xóa.', '❌');
                    });
                },
                true
            );
        }

        document.querySelectorAll('.message:not(.user) .message-bubble').forEach(function(el) {
            var rawText = el.textContent || el.innerText;
            if (rawText && rawText.trim() && typeof marked !== 'undefined') {
                el.innerHTML = marked.parse(rawText);
            }
        });

        var area = document.getElementById('messagesArea');
        if (area) {
            area.scrollTop = area.scrollHeight;
        }
    </script>
}
