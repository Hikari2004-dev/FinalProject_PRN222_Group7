@page
@model FinalProject_PRN222_Group7.Pages.Chat.IndexModel
@{
    ViewData["Title"] = "AI Chatbot";
}

@section Styles {
    <style>
        .page-content {
            padding: 0;
        }

        .chat-layout {
            min-height: calc(100vh - var(--topbar-h));
        }

        .message-bubble p {
            margin-bottom: 8px;
            line-height: 1.6;
        }

        .message-bubble p:last-child {
            margin-bottom: 0;
        }

        .message-bubble ul, .message-bubble ol {
            margin-left: 20px;
            margin-bottom: 8px;
            padding-left: 0;
        }

        .message-bubble li {
            margin-bottom: 4px;
            line-height: 1.5;
        }

        .message-bubble h1, .message-bubble h2, .message-bubble h3, .message-bubble h4 {
            font-size: 0.95rem;
            font-weight: 600;
            margin-top: 12px;
            margin-bottom: 6px;
            color: var(--text-primary);
        }
    </style>
}

<div class="chat-layout">
    <div class="chat-sidebar">
        <div class="chat-sidebar-header">
            <button onclick="newChat()" class="btn btn-primary w-full btn-sm">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                Chat mới
            </button>
            <div style="margin-top:10px">
                <input type="text" id="searchSessions" class="form-control" placeholder="Tìm chat..." style="font-size:0.8rem;padding:7px 12px" oninput="filterSessions(this.value)" />
            </div>
        </div>

        <div class="chat-sessions" id="sessionsList">
            @if (Model.Sessions.Any())
            {
                @foreach (var s in Model.Sessions)
                {
                    <div class="chat-session-item @(s.Id == Model.ActiveSessionId ? "active" : "")"
                         onclick="loadSession(@s.Id)"
                         data-title="@s.Title.ToLower()"
                         style="position:relative;display:flex;justify-content:space-between;align-items:center;padding-right:32px;">
                        <div>
                            <div class="chat-session-title">@s.Title</div>
                            <div class="chat-session-time">@s.UpdatedAt.ToString("dd/MM HH:mm")</div>
                        </div>
                        <button type="button" onclick="deleteSession(@s.Id, '@Html.Raw(s.Title.Replace("'", "\\'"))', event)" style="position:absolute;right:8px;top:50%;transform:translateY(-50%);background:none;border:none;color:var(--text-muted);cursor:pointer;padding:4px;display:flex;align-items:center;justify-content:center;border-radius:var(--radius);transition:all 0.2s" onmouseover="this.style.background='var(--danger-muted)';this.style.color='var(--danger)'" onmouseout="this.style.background='none';this.style.color='var(--text-muted)'" title="Xóa lịch sử chat">
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/><line x1="10" y1="11" x2="10" y2="17"/><line x1="14" y1="11" x2="14" y2="17"/></svg>
                        </button>
                    </div>
                }
            }
            else
            {
                <div style="padding:20px;text-align:center;font-size:0.8rem;color:var(--text-muted)">Chưa có chat nào</div>
            }
        </div>
    </div>

    <div class="chat-main">
        <div style="padding:14px 20px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:12px;background:var(--bg-surface)">
            <div style="width:34px;height:34px;background:linear-gradient(135deg,var(--accent),#8b5cf6);border-radius:8px;display:flex;align-items:center;justify-content:center">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
            </div>
            <div>
                <div style="font-weight:600;font-size:0.9rem" id="chatTitle">@(Model.ActiveSession?.Title ?? "AI Chatbot")</div>
                <div style="font-size:0.72rem;color:var(--success);display:flex;align-items:center;gap:4px">
                    <span style="width:6px;height:6px;background:var(--success);border-radius:50%;display:inline-block"></span>
                    Sẵn sàng
                </div>
            </div>

            <div style="margin-left:auto;display:flex;align-items:center;gap:10px">
                <select id="courseSelector" class="form-control" style="width:160px;font-size:0.78rem;padding:6px 10px" @(Model.ActiveSessionId.HasValue ? "disabled" : "")>
                    <option value="">-- Chọn môn học --</option>
                    @foreach (var c in Model.Courses)
                    {
                        <option value="@c.Id" selected="@(Model.ActiveSession?.CourseId == c.Id)">@c.Name</option>
                    }
                </select>
            </div>
        </div>

        <div class="chat-messages" id="messagesArea">
            @if (Model.ActiveSession == null || !Model.ActiveSession.Messages.Any())
            {
                <div id="welcomeState" style="flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;gap:16px">
                    <div style="width:64px;height:64px;background:linear-gradient(135deg,var(--accent),#8b5cf6);border-radius:var(--radius-lg);display:flex;align-items:center;justify-content:center;box-shadow:var(--shadow-accent)">
                        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
                    </div>
                    <div>
                        <h2 style="font-size:1.2rem;font-weight:700;color:var(--text-primary);margin-bottom:6px">Xin chào! Tôi là AI học tập</h2>
                        <p style="font-size:0.875rem;color:var(--text-secondary);max-width:320px">Tôi sẽ trả lời câu hỏi dựa trên tài liệu học tập của bạn. Hãy chọn môn học và bắt đầu hỏi!</p>
                    </div>
                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;max-width:400px;width:100%">
                        @foreach (var q in new[] { "Tóm tắt nội dung chương 1?", "Giải thích khái niệm X?", "Cho ví dụ về Y?", "So sánh A và B?" })
                        {
                            <button onclick="document.getElementById('chatInput').value='@q';document.getElementById('chatInput').focus()"
                                    style="padding:10px 14px;background:var(--bg-elevated);border:1px solid var(--border);border-radius:var(--radius);text-align:left;cursor:pointer;font-size:0.8rem;color:var(--text-secondary);transition:all 0.15s;font-family:var(--font-sans)"
                                    onmouseenter="this.style.borderColor='var(--border-hover)';this.style.background='var(--bg-hover)'"
                                    onmouseleave="this.style.borderColor='var(--border)';this.style.background='var(--bg-elevated)'">
                                @q
                            </button>
                        }
                    </div>
                </div>
            }
            else
            {
                @foreach (var msg in Model.ActiveSession.Messages)
                {
                    <div class="message @(msg.Role == FinalProject_PRN222_Group7.DAL.Entities.MessageRole.User ? "user" : "")">
                        <div class="message-avatar">
                            @(msg.Role == FinalProject_PRN222_Group7.DAL.Entities.MessageRole.User ? Model.UserInitials : "AI")
                        </div>
                        <div>
                            <div class="message-bubble">@msg.Content</div>
                            @if (msg.SourceCitations != null)
                            {
                                <div class="message-citations">
                                    <span style="font-size:0.7rem;color:var(--text-muted)">Nguồn:</span>
                                    @foreach (var cite in msg.SourceCitations.Split(',', StringSplitOptions.RemoveEmptyEntries))
                                    {
                                        <span class="citation-pill">@cite.Trim()</span>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                }
            }
        </div>

        <div class="chat-input-area">
            <div class="chat-input-wrapper" id="inputWrapper">
                <textarea id="chatInput" class="chat-textarea" data-autoresize
                          placeholder="Nhập câu hỏi về tài liệu..."
                          rows="1"
                          onkeydown="handleKeyDown(event)"></textarea>
                <button id="sendBtn" class="chat-send-btn" onclick="sendMessage()" title="Gửi (Enter)">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
                </button>
            </div>
            <div class="chat-meta">
                <span>Enter để gửi, Shift+Enter xuống dòng</span>
                <span class="queries-remaining">Còn @(Model.RemainingQueries == int.MaxValue ? "vô hạn" : Model.RemainingQueries + " AI credit")</span>
            </div>
        </div>
    </div>
</div>

@Html.AntiForgeryToken()

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
    <script>
        var activeSessionId = @(Model.ActiveSessionId?.ToString() ?? "null");
        var antiForgeryToken = document.querySelector('input[name="__RequestVerificationToken"]')?.value;

        function newChat() {
            activeSessionId = null;
            document.getElementById('chatTitle').textContent = 'AI Chatbot';
            var selector = document.getElementById('courseSelector');
            if (selector) {
                selector.value = "";
                selector.removeAttribute('disabled');
            }
            var area = document.getElementById('messagesArea');
            area.innerHTML = '<div style="flex:1;display:flex;align-items:center;justify-content:center;color:var(--text-muted);font-size:0.875rem">Bắt đầu cuộc trò chuyện mới...</div>';
            document.querySelectorAll('.chat-session-item').forEach(el => el.classList.remove('active'));
        }

        function loadSession(id) {
            window.location.href = '/Chat/Session/' + id;
        }

        function filterSessions(val) {
            document.querySelectorAll('.chat-session-item').forEach(function(el) {
                el.style.display = el.dataset.title.includes(val.toLowerCase()) ? '' : 'none';
            });
        }

        function handleKeyDown(e) {
            if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendMessage(); }
            var ta = document.getElementById('chatInput');
            setTimeout(function() {
                ta.style.height = 'auto';
                ta.style.height = Math.min(ta.scrollHeight, 160) + 'px';
            }, 0);
        }

        async function sendMessage() {
            var courseId = document.getElementById('courseSelector').value;
            if (!courseId) {
                showAlert('Chưa chọn môn học', 'Vui lòng chọn môn học trước khi bắt đầu chat!', '⚠️');
                return;
            }

            var input = document.getElementById('chatInput');
            var msg = input.value.trim();
            if (!msg) return;

            var area = document.getElementById('messagesArea');
            var welcome = document.getElementById('welcomeState');
            if (welcome) welcome.remove();

            appendMessage('user', msg, null);
            input.value = '';
            input.style.height = 'auto';

            var typingDiv = document.createElement('div');
            typingDiv.className = 'message';
            typingDiv.id = 'typingIndicator';
            typingDiv.innerHTML = '<div class="message-avatar">AI</div><div class="message-bubble"><div class="typing-indicator"><div class="typing-dot"></div><div class="typing-dot"></div><div class="typing-dot"></div></div></div>';
            area.appendChild(typingDiv);
            area.scrollTop = area.scrollHeight;

            try {
                var courseId = document.getElementById('courseSelector').value;
                var res = await fetch('/api/chat/send', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': antiForgeryToken },
                    body: JSON.stringify({ question: msg, sessionId: activeSessionId, courseId: courseId || null })
                });
                var data = await res.json();

                typingDiv.remove();

                if (data.sessionId) {
                    activeSessionId = data.sessionId;
                    var selector = document.getElementById('courseSelector');
                    if (selector) {
                        selector.setAttribute('disabled', 'disabled');
                    }
                }
                appendMessage('ai', data.answer, data.citations);
            } catch (err) {
                typingDiv.remove();
                appendMessage('ai', 'Xin lỗi, đã có lỗi xảy ra. Vui lòng thử lại.', null);
            }
        }

        function appendMessage(role, content, citations) {
            var area = document.getElementById('messagesArea');
            var div = document.createElement('div');
            div.className = 'message' + (role === 'user' ? ' user' : '');

            var avatarText = role === 'user' ? '@Model.UserInitials' : 'AI';
            var citeHtml = '';
            if (citations && citations.length > 0) {
                citeHtml = '<div class="message-citations"><span style="font-size:0.7rem;color:var(--text-muted)">Nguồn:</span>';
                citations.forEach(function(c) { citeHtml += '<span class="citation-pill">' + c + '</span>'; });
                citeHtml += '</div>';
            }

            var renderedContent = role === 'user' ? escapeHtml(content) : marked.parse(content);
            div.innerHTML = '<div class="message-avatar">' + avatarText + '</div><div><div class="message-bubble">' + renderedContent + '</div>' + citeHtml + '</div>';
            area.appendChild(div);
            area.scrollTop = area.scrollHeight;
        }

        function escapeHtml(t) {
            var d = document.createElement('div');
            d.appendChild(document.createTextNode(t));
            return d.innerHTML;
        }

        function deleteSession(sessionId, title, event) {
            if (event) event.stopPropagation();

            showConfirm(
                'Xóa lịch sử trò chuyện',
                `Bạn có chắc chắn muốn xóa lịch sử trò chuyện "${title}" không? Hành động này sẽ xóa toàn bộ nội dung trò chuyện và không thể phục hồi!`,
                '🗑️',
                () => {
                    const formData = new FormData();
                    formData.append('sessionId', sessionId);

                    fetch('?handler=DeleteSession', {
                        method: 'POST',
                        body: formData,
                        headers: {
                            'RequestVerificationToken': antiForgeryToken
                        }
                    })
                    .then(res => res.json())
                    .then(data => {
                        if (data.success) {
                            showAlert('Đã xóa', 'Lịch sử cuộc trò chuyện đã được xóa thành công.', '✅', () => {
                                window.location.href = '/Chat';
                            });
                        } else {
                            showAlert('Lỗi', data.error || 'Không thể xóa cuộc trò chuyện.', '❌');
                        }
                    })
                    .catch(err => {
                        showAlert('Lỗi kết nối', 'Không thể kết nối với hệ thống để xóa.', '❌');
                    });
                },
                true
            );
        }

        document.querySelectorAll('.message:not(.user) .message-bubble').forEach(function(el) {
            var rawText = el.textContent || el.innerText;
            if (rawText && rawText.trim()) {
                el.innerHTML = marked.parse(rawText);
            }
        });

        var area = document.getElementById('messagesArea');
        if (area) {
            area.scrollTop = area.scrollHeight;
        }
    </script>
}
