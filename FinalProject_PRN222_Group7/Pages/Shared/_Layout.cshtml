@using Microsoft.AspNetCore.Identity
@inject SignInManager<FinalProject_PRN222_Group7.DAL.Entities.AppUser> SignInManager
@inject UserManager<FinalProject_PRN222_Group7.DAL.Entities.AppUser> UserManager

@{
    var user = await UserManager.GetUserAsync(User);
    var roles = user != null ? await UserManager.GetRolesAsync(user) : new List<string>();
    var role = roles.FirstOrDefault() ?? "Guest";
    var currentPage = ViewContext.RouteData.Values["page"]?.ToString() ?? "";
    var initials = user?.FullName?.Split(' ').Select(n => n[0]).Take(2).ToArray() is char[] arr && arr.Length > 0
        ? new string(arr).ToUpper() : "?";

    bool isAdmin    = role == "Admin";
    bool isLecturer = role == "Lecturer";
    bool isStudent  = role == "Student";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] != null ? ViewData["Title"] + " - LMS AI" : "LMS AI Platform")</title>
    <link rel="stylesheet" href="~/css/app.css" asp-append-version="true" />
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'><rect width='32' height='32' rx='8' fill='%236366f1'/><text x='16' y='22' text-anchor='middle' font-size='18' font-weight='bold' fill='white'>L</text></svg>" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

<!-- ═══════════════════════════════════════════════════════════════════════
     LAYOUT: FULL WIDTH - TOPBAR WITH TABS (NO SIDEBAR)
════════════════════════════════════════════════════════════════════════ -->

<div class="lms-app">

    <!-- ── Top Header (Logo + Tabs + User) ─────────────────────────── -->
    <header class="lms-topbar">
        
        <!-- Logo -->
        <a href="/Dashboard" class="topbar-brand">
            <div class="topbar-brand-icon">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5">
                    <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
                </svg>
            </div>
            <span class="topbar-brand-text">LMS AI</span>
        </a>

        <!-- Navigation Tabs -->
        <nav class="topbar-tabs">
            <a href="/Dashboard" class="topbar-tab @(currentPage.StartsWith("/Dashboard") ? "active" : "")">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="9"/><rect x="14" y="3" width="7" height="5"/><rect x="14" y="12" width="7" height="9"/><rect x="3" y="16" width="7" height="5"/></svg>
                Dashboard
            </a>
            
            <a href="/Chat" class="topbar-tab @(currentPage.StartsWith("/Chat") ? "active" : "")">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
                AI Chatbot
            </a>
            
            <a href="/Quiz" class="topbar-tab @(currentPage.StartsWith("/Quiz") ? "active" : "")">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 015.83 1c0 2-3 3-3 3M12 17h.01"/></svg>
                Quiz
            </a>

            @if (isStudent || isLecturer || isAdmin)
            {
                <a href="/Courses" class="topbar-tab @(currentPage.StartsWith("/Courses") ? "active" : "")">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 016.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 014 19.5v-15A2.5 2.5 0 016.5 2z"/></svg>
                    Môn học
                </a>
            }

            @if (isAdmin || isLecturer)
            {
                <a href="/Benchmark" class="topbar-tab @(currentPage.StartsWith("/Benchmark") ? "active" : "")">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22,12 18,12 15,21 9,3 6,12 2,12"/></svg>
                    Benchmark
                </a>
            }

            <a href="/Packages" class="topbar-tab @(currentPage.StartsWith("/Packages") ? "active" : "")">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 21V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v16"/></svg>
                Gói dịch vụ
            </a>

            @if (isAdmin)
            {
                <a href="/Admin" class="topbar-tab @(currentPage.StartsWith("/Admin") ? "active" : "")">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                    Quản trị
                </a>
            }
        </nav>

        <!-- User Actions -->
        <div class="topbar-actions">
            <button class="topbar-icon-btn" title="Thông báo">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 01-3.46 0"/></svg>
                <span class="topbar-badge"></span>
            </button>
            
            <div class="topbar-user">
                <div class="topbar-avatar">@initials</div>
                <div class="topbar-user-info">
                    <span class="topbar-user-name">@(user?.FullName ?? "Guest")</span>
                    <span class="topbar-user-role">@role</span>
                </div>
                <form method="post" action="/Auth/Logout" style="display:inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="topbar-logout" title="Đăng xuất">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                    </button>
                </form>
            </div>
        </div>
    </header>

    <!-- ── Page Content ─────────────────────────────────────────────── -->
    <main class="lms-content">
        @RenderBody()
    </main>
</div>

<!-- ═══════════════════════════════════════════════════════════════════════
     GLOBAL MODALS
════════════════════════════════════════════════════════════════════════ -->

<div id="globalAlertModal" class="lms-modal-overlay">
    <div class="lms-modal-box">
        <div class="lms-modal-icon" id="globalAlertIcon">🔔</div>
        <h3 class="lms-modal-title" id="globalAlertTitle">Thông báo</h3>
        <p class="lms-modal-message" id="globalAlertMessage">Nội dung thông báo.</p>
        <button type="button" class="btn btn-primary" onclick="closeGlobalAlert()">Đóng</button>
    </div>
</div>

<div id="globalConfirmModal" class="lms-modal-overlay">
    <div class="lms-modal-box">
        <div class="lms-modal-icon" id="globalConfirmIcon">⚠️</div>
        <h3 class="lms-modal-title" id="globalConfirmTitle">Xác nhận</h3>
        <p class="lms-modal-message" id="globalConfirmMessage">Bạn có chắc chắn?</p>
        <div class="lms-modal-actions">
            <button type="button" class="btn btn-secondary" onclick="closeGlobalConfirm()">Hủy</button>
            <button type="button" class="btn btn-primary" id="globalConfirmSubmitBtn">Đồng ý</button>
        </div>
    </div>
</div>

<div id="globalToastContainer" class="lms-toast-container"></div>

<!-- ═══════════════════════════════════════════════════════════════════════
     JAVASCRIPT
════════════════════════════════════════════════════════════════════════ -->

<script>
window.showAlert = function(title, message, icon, onClose) {
    document.getElementById('globalAlertTitle').innerText = title || 'Thông báo';
    document.getElementById('globalAlertMessage').innerText = message || '';
    document.getElementById('globalAlertIcon').innerText = icon || '🔔';
    document.getElementById('globalAlertModal').style.display = 'flex';
    window._alertOnClose = onClose || null;
};

window.closeGlobalAlert = function() {
    document.getElementById('globalAlertModal').style.display = 'none';
    if (window._alertOnClose) { window._alertOnClose(); window._alertOnClose = null; }
};

window.showConfirm = function(title, message, icon, onConfirm, isDanger = false) {
    document.getElementById('globalConfirmTitle').innerText = title || 'Xác nhận';
    document.getElementById('globalConfirmMessage').innerText = message || '';
    document.getElementById('globalConfirmIcon').innerText = icon || '⚠️';
    const submitBtn = document.getElementById('globalConfirmSubmitBtn');
    submitBtn.disabled = false;
    submitBtn.innerHTML = 'Đồng ý';
    submitBtn.className = isDanger ? 'btn btn-danger' : 'btn btn-primary';
    window._confirmCallback = onConfirm;
    document.getElementById('globalConfirmModal').style.display = 'flex';
};

window.closeGlobalConfirm = function() {
    document.getElementById('globalConfirmModal').style.display = 'none';
    window._confirmCallback = null;
};

document.getElementById('globalConfirmSubmitBtn').addEventListener('click', function() {
    if (this.disabled) return;
    this.disabled = true;
    this.innerHTML = '<span class="btn-spinner"></span>';
    if (window._confirmCallback) window._confirmCallback();
    closeGlobalConfirm();
});

window.setButtonLoading = function(btn, msg) {
    if (!btn) return;
    btn._originalHTML = btn.innerHTML;
    btn.disabled = true;
    btn.innerHTML = '<span class="btn-spinner"></span>' + (msg || 'Đang xử lý...');
};

window.resetButton = function(btn) {
    if (!btn) return;
    btn.disabled = false;
    btn.innerHTML = btn._originalHTML || btn.innerText;
};

window.showToast = function(title, message, icon = '🔔', duration = 8000, actionCallback, actionText) {
    const container = document.getElementById('globalToastContainer');
    if (!container) return;
    const toast = document.createElement('div');
    toast.className = 'lms-toast';
    let actionBtn = actionCallback ? '<button class="lms-toast-action">' + (actionText || 'Tải lại') + '</button>' : '';
    toast.innerHTML = '<div class="lms-toast-icon">' + icon + '</div><div class="lms-toast-body"><div class="lms-toast-title">' + title + '</div><div class="lms-toast-message">' + message + '</div>' + actionBtn + '</div><button class="lms-toast-close" onclick="this.parentElement.remove()">✕</button>';
    if (actionCallback) toast.querySelector('.lms-toast-action').onclick = () => { actionCallback(); toast.remove(); };
    container.appendChild(toast);
    setTimeout(() => { toast.classList.add('lms-toast-out'); setTimeout(() => toast.remove(), 300); }, duration);
};

document.querySelectorAll('textarea[data-autoresize]').forEach(function(el) {
    el.addEventListener('input', function() {
        this.style.height = 'auto';
        this.style.height = Math.min(this.scrollHeight, 160) + 'px';
    });
});
</script>

@if (User.Identity?.IsAuthenticated == true)
{
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.min.js"></script>
    <script>
    const lmsConnection = new signalR.HubConnectionBuilder().withUrl("/lmsHub").build();
    lmsConnection.on("ReceiveCourseUpdate", () => {
        if (window.location.pathname.toLowerCase().includes("/courses")) {
            window.location.reload();
        } else {
            window.showToast("Cập nhật môn học", "Có môn học mới vừa được cập nhật.", "📚", 10000, () => window.location.reload(), "Tải lại");
        }
    });
    lmsConnection.start().catch(err => console.error("SignalR Error: ", err));
    </script>
}

@await RenderSectionAsync("Scripts", required: false)

</body>
</html>
