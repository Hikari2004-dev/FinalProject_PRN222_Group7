@using Microsoft.AspNetCore.Identity
@inject SignInManager<FinalProject_PRN222_Group7.DAL.Entities.AppUser> SignInManager
@inject UserManager<FinalProject_PRN222_Group7.DAL.Entities.AppUser> UserManager

@{
    var user = await UserManager.GetUserAsync(User);
    var roles = user != null ? await UserManager.GetRolesAsync(user) : new List<string>();
    var role = roles.FirstOrDefault() ?? "Guest";
    var currentPage = ViewContext.RouteData.Values["page"]?.ToString() ?? "";
    var initials = user?.FullName?.Split(' ').Select(n => n[0]).Take(2).ToArray() is char[] arr && arr.Length > 0
        ? new string(arr).ToUpper() : "?";

    bool isAdmin    = role == "Admin";
    bool isLecturer = role == "Lecturer";
    bool isStudent  = role == "Student";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] != null ? ViewData["Title"] + " - LMS AI" : "LMS AI Platform")</title>
    <meta name="description" content="Hệ thống học tập thông minh với AI RAG Chatbot" />
    <link rel="stylesheet" href="~/css/app.css" asp-append-version="true" />
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'><rect width='32' height='32' rx='6' fill='%233b82f6'/><text x='16' y='22' text-anchor='middle' font-size='18' font-weight='bold' fill='white'>L</text></svg>" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
<div class="app-shell">

    <!-- ── Sidebar ──────────────────────────────────────────────── -->
    <aside class="sidebar" id="sidebar">

        <!-- Logo -->
        <div class="sidebar-logo">
            <div class="sidebar-logo-icon">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round">
                    <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
                </svg>
            </div>
            <span class="sidebar-logo-text">LMS&nbsp;AI</span>
        </div>

        <!-- Navigation -->
        <nav class="sidebar-nav">

            <div class="nav-section-label">Tổng quan</div>
            <a href="/Dashboard" class="nav-item @(currentPage.StartsWith("/Dashboard") ? "active" : "")">
                <span class="nav-item-icon">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
                </span>
                <span class="nav-item-text">Dashboard</span>
            </a>

            <div class="nav-section-label">Học tập</div>
            <a href="/Chat" class="nav-item @(currentPage.StartsWith("/Chat") ? "active" : "")">
                <span class="nav-item-icon">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
                </span>
                <span class="nav-item-text">AI Chatbot</span>
            </a>

            <a href="/Quiz" class="nav-item @(currentPage.StartsWith("/Quiz") ? "active" : "")">
                <span class="nav-item-icon">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 015.83 1c0 2-3 3-3 3M12 17h.01"/></svg>
                </span>
                <span class="nav-item-text">Quiz</span>
            </a>

            @if (isLecturer || isAdmin)
            {
                <div class="nav-section-label">Giảng dạy</div>
                <a href="/Courses" class="nav-item @(currentPage.StartsWith("/Courses") ? "active" : "")">
                    <span class="nav-item-icon">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M4 19.5A2.5 2.5 0 016.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 014 19.5v-15A2.5 2.5 0 016.5 2z"/></svg>
                    </span>
                    <span class="nav-item-text">Môn học</span>
                </a>
            }

            <div class="nav-section-label">Phân tích</div>
            <a href="/Reports" class="nav-item @(currentPage.StartsWith("/Reports") ? "active" : "")">
                <span class="nav-item-icon">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
                </span>
                <span class="nav-item-text">Báo cáo</span>
            </a>

            @if (isAdmin || isLecturer)
            {
                <a href="/Benchmark" class="nav-item @(currentPage.StartsWith("/Benchmark") ? "active" : "")">
                    <span class="nav-item-icon">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="22,12 18,12 15,21 9,3 6,12 2,12"/></svg>
                    </span>
                    <span class="nav-item-text">Benchmark</span>
                </a>
            }

            <div class="nav-section-label">Tài khoản</div>
            <a href="/Packages" class="nav-item @(currentPage.StartsWith("/Packages") ? "active" : "")">
                <span class="nav-item-icon">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 21V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v16"/></svg>
                </span>
                <span class="nav-item-text">Gói dịch vụ</span>
            </a>

            @if (isAdmin)
            {
                <div class="nav-section-label">Quản trị</div>
                <a href="/Admin" class="nav-item @(currentPage.StartsWith("/Admin") ? "active" : "")">
                    <span class="nav-item-icon">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                    </span>
                    <span class="nav-item-text">Quản trị</span>
                </a>
            }

        </nav>

        <!-- User Card -->
        <div class="sidebar-footer">
            <div class="user-card" onclick="window.location='/Auth/Logout'">
                <div class="user-avatar">@initials</div>
                <div class="user-info">
                    <div class="user-name">@(user?.FullName ?? "Guest")</div>
                    <div class="user-role">@role</div>
                </div>
            </div>
        </div>
    </aside>

    <!-- ── Main ──────────────────────────────────────────────────── -->
    <div class="main-content" id="mainContent">

        <!-- Topbar -->
        <header class="topbar">
            <button class="topbar-toggle" id="sidebarToggle" aria-label="Toggle sidebar">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
            </button>

            <div class="topbar-breadcrumb">
                <span>LMS AI</span>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
                <span class="current">@(ViewData["Title"] ?? "Dashboard")</span>
            </div>

            <div class="topbar-actions">
                <button class="topbar-btn" title="Thông báo">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 01-3.46 0"/></svg>
                    <span class="topbar-notif-dot"></span>
                </button>
                <form method="post" action="/Auth/Logout" style="margin:0">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="topbar-btn" title="Đăng xuất">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                    </button>
                </form>
            </div>
        </header>

        <!-- Page Content -->
        <main class="page-content fade-in">
            @RenderBody()
        </main>

    </div><!-- end main-content -->

</div><!-- end app-shell -->

<!-- Sidebar overlay for mobile -->
<div id="sidebarOverlay" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.6);z-index:99" onclick="closeSidebar()"></div>

<!-- Global Custom Alert Modal -->
<div id="globalAlertModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.65);z-index:9999;align-items:center;justify-content:center">
    <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius-xl);padding:26px;width:100%;max-width:400px;box-shadow:var(--shadow-lg);text-align:center;animation: globalModalFadeIn 0.25s cubic-bezier(0.16, 1, 0.3, 1)">
        <div style="font-size:2.8rem;margin-bottom:12px" id="globalAlertIcon">🔔</div>
        <h3 style="font-size:1.05rem;font-weight:700;color:var(--text-primary);margin-bottom:10px" id="globalAlertTitle">Thông báo</h3>
        <p style="font-size:0.825rem;color:var(--text-muted);margin-bottom:24px;line-height:1.5" id="globalAlertMessage">Nội dung thông báo.</p>
        <button type="button" class="btn btn-primary" onclick="closeGlobalAlert()" style="width:100%;font-size:0.8rem;padding:10px 16px;height:auto">Đóng</button>
    </div>
</div>

<!-- Global Custom Confirm Modal -->
<div id="globalConfirmModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.65);z-index:9998;align-items:center;justify-content:center">
    <div style="background:var(--bg-card);border:1px solid var(--border);border-radius:var(--radius-xl);padding:26px;width:100%;max-width:420px;box-shadow:var(--shadow-lg);text-align:center;animation: globalModalFadeIn 0.25s cubic-bezier(0.16, 1, 0.3, 1)">
        <div style="font-size:2.8rem;margin-bottom:12px" id="globalConfirmIcon">⚠️</div>
        <h3 style="font-size:1.05rem;font-weight:700;color:var(--text-primary);margin-bottom:10px" id="globalConfirmTitle">Xác nhận</h3>
        <p style="font-size:0.825rem;color:var(--text-muted);margin-bottom:24px;line-height:1.5" id="globalConfirmMessage">Bạn có chắc chắn muốn thực hiện hành động này?</p>
        <div style="display:flex;gap:10px;justify-content:center">
            <button type="button" class="btn btn-secondary" onclick="closeGlobalConfirm()" style="flex:1;font-size:0.8rem;padding:10px 16px;height:auto">Hủy</button>
            <button type="button" class="btn" id="globalConfirmSubmitBtn" style="flex:1;font-size:0.8rem;padding:10px 16px;height:auto">Đồng ý</button>
        </div>
    </div>
</div>

<style>
    @@keyframes globalModalFadeIn {
        from { transform: scale(0.96); opacity: 0; }
        to { transform: scale(1); opacity: 1; }
    }
</style>

<script>
    // Global Custom Dialog Handlers
    let activeGlobalConfirmCallback = null;

    window.showAlert = function(title, message, icon, onClose) {
        document.getElementById('globalAlertTitle').innerText = title || 'Thông báo';
        document.getElementById('globalAlertMessage').innerText = message || '';
        document.getElementById('globalAlertIcon').innerText = icon || '🔔';
        document.getElementById('globalAlertModal').style.display = 'flex';
        window._alertOnClose = onClose || null;
    };

    window.closeGlobalAlert = function() {
        document.getElementById('globalAlertModal').style.display = 'none';
        if (window._alertOnClose) { window._alertOnClose(); window._alertOnClose = null; }
    };

    window.showConfirm = function(title, message, icon, onConfirm, isDanger = false) {
        document.getElementById('globalConfirmTitle').innerText = title || 'Xác nhận';
        document.getElementById('globalConfirmMessage').innerText = message || '';
        document.getElementById('globalConfirmIcon').innerText = icon || '⚠️';
        
        const submitBtn = document.getElementById('globalConfirmSubmitBtn');
        // Reset button state in case previous confirm left it disabled
        submitBtn.disabled = false;
        submitBtn.innerHTML = 'Xác nhận';
        if (isDanger) {
            submitBtn.className = 'btn btn-danger';
            submitBtn.style.background = 'var(--danger)';
            submitBtn.style.border = '1px solid var(--danger)';
            submitBtn.style.color = '#fff';
        } else {
            submitBtn.className = 'btn btn-primary';
            submitBtn.style.background = 'var(--accent)';
            submitBtn.style.border = '1px solid var(--accent)';
            submitBtn.style.color = '#fff';
        }

        activeGlobalConfirmCallback = onConfirm;
        document.getElementById('globalConfirmModal').style.display = 'flex';
    };

    window.closeGlobalConfirm = function() {
        document.getElementById('globalConfirmModal').style.display = 'none';
        activeGlobalConfirmCallback = null;
    };

    document.getElementById('globalConfirmSubmitBtn').addEventListener('click', function() {
        if (this.disabled) return;
        // Disable button immediately to prevent double-click
        this.disabled = true;
        this.innerHTML = '<span style="display:inline-flex;align-items:center;gap:6px"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="animation:spin 1s linear infinite"><path d="M21 12a9 9 0 1 1-6.219-8.56"/></svg>Đang xử lý...</span>';
        if (activeGlobalConfirmCallback) {
            activeGlobalConfirmCallback();
        }
        closeGlobalConfirm();
    });

    // ─── Prevent Duplicate Submissions ─────────────────────────────────────────
    // setButtonLoading(btn, msg?) → disables button, shows spinner + msg
    // resetButton(btn)            → restores original state (on error)
    window.setButtonLoading = function(btn, msg) {
        if (!btn) return;
        btn._originalHTML = btn.innerHTML;
        btn._originalDisabled = btn.disabled;
        btn.disabled = true;
        btn.innerHTML = `<span style="display:inline-flex;align-items:center;gap:6px">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="animation:spin 1s linear infinite;flex-shrink:0"><path d="M21 12a9 9 0 1 1-6.219-8.56"/></svg>
            ${msg || 'Đang xử lý...'}
        </span>`;
    };

    window.resetButton = function(btn) {
        if (!btn) return;
        btn.disabled = btn._originalDisabled || false;
        btn.innerHTML = btn._originalHTML || btn.innerText;
    };
</script>

<!-- Global Toast Notification Container -->
<div id="globalToastContainer" style="position: fixed; top: 20px; right: 20px; z-index: 9999; display: flex; flex-direction: column; gap: 10px; pointer-events: none;"></div>

<style>
    #globalToastContainer > div {
        pointer-events: auto;
    }
    @@keyframes toastFadeIn {
        from { transform: translateY(-10px); opacity: 0; }
        to { transform: translateY(0); opacity: 1; }
    }
</style>

@if (User.Identity?.IsAuthenticated == true)
{
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.min.js"></script>
    <script>
        window.showToast = function(title, message, icon = '🔔', duration = 8000, actionCallback = null, actionText = 'Tải lại') {
            const container = document.getElementById('globalToastContainer');
            if (!container) return;

            const toast = document.createElement('div');
            toast.style.background = 'var(--bg-card)';
            toast.style.border = '1px solid var(--border)';
            toast.style.borderRadius = 'var(--radius)';
            toast.style.padding = '12px 16px';
            toast.style.minWidth = '300px';
            toast.style.maxWidth = '380px';
            toast.style.boxShadow = 'var(--shadow-lg)';
            toast.style.display = 'flex';
            toast.style.alignItems = 'flex-start';
            toast.style.gap = '12px';
            toast.style.animation = 'toastFadeIn 0.3s cubic-bezier(0.16, 1, 0.3, 1)';
            toast.style.transition = 'all 0.3s';

            let actionBtnHtml = '';
            if (actionCallback) {
                actionBtnHtml = `<button class="btn btn-primary btn-sm" style="margin-top: 8px; padding: 4px 12px; font-size: 0.72rem; font-weight: 600;">${actionText}</button>`;
            }

            toast.innerHTML = `
                <div style="font-size: 1.25rem; flex-shrink: 0; line-height: 1;">${icon}</div>
                <div style="flex: 1;">
                    <div style="font-size: 0.85rem; font-weight: 600; color: var(--text-primary); margin-bottom: 2px;">${title}</div>
                    <div style="font-size: 0.78rem; color: var(--text-muted); line-height: 1.4;">${message}</div>
                    ${actionBtnHtml}
                </div>
                <button style="background: none; border: none; color: var(--text-muted); cursor: pointer; font-size: 1rem; padding: 0; line-height: 1; margin-left: 8px; margin-top: 2px;" onclick="this.parentElement.remove()">✕</button>
            `;

            if (actionCallback) {
                toast.querySelector('button.btn-primary').addEventListener('click', () => {
                    actionCallback();
                    toast.remove();
                });
            }

            container.appendChild(toast);

            setTimeout(() => {
                toast.style.opacity = '0';
                toast.style.transform = 'translateY(-10px)';
                setTimeout(() => toast.remove(), 300);
            }, duration);
        };

        // Initialize Global SignalR connection
        const lmsConnection = new signalR.HubConnectionBuilder()
            .withUrl("/lmsHub")
            .build();

        lmsConnection.on("ReceiveCourseUpdate", () => {
            const pathname = window.location.pathname.toLowerCase();
            if (pathname.includes("/courses")) {
                // If on courses management page, reload immediately to sync data
                window.location.reload();
            } else {
                // Otherwise, show toast notification to avoid interrupting user activity
                window.showToast(
                    "Cập nhật môn học",
                    "Có môn học mới hoặc tài liệu mới vừa được cập nhật hệ thống.",
                    "📚",
                    10000,
                    () => window.location.reload(),
                    "Tải lại trang"
                );
            }
        });

        lmsConnection.start().catch(err => console.error("SignalR Connection Error: ", err.toString()));
    </script>
}


@await RenderSectionAsync("Scripts", required: false)

<script>
(function () {
    const sidebar = document.getElementById('sidebar');
    const main = document.getElementById('mainContent');
    const overlay = document.getElementById('sidebarOverlay');
    const toggle = document.getElementById('sidebarToggle');
    const COLLAPSED_KEY = 'sidebar_collapsed';

    // Restore state
    if (localStorage.getItem(COLLAPSED_KEY) === '1' && window.innerWidth > 1024) {
        sidebar.classList.add('collapsed');
        main.classList.add('sidebar-collapsed');
    }

    toggle.addEventListener('click', function () {
        if (window.innerWidth <= 1024) {
            // Mobile: overlay toggle
            if (sidebar.classList.contains('mobile-open')) {
                closeSidebar();
            } else {
                sidebar.classList.add('mobile-open');
                overlay.style.display = 'block';
            }
        } else {
            // Desktop: collapse toggle
            const collapsed = sidebar.classList.toggle('collapsed');
            main.classList.toggle('sidebar-collapsed', collapsed);
            localStorage.setItem(COLLAPSED_KEY, collapsed ? '1' : '0');
        }
    });

    window.closeSidebar = function () {
        sidebar.classList.remove('mobile-open');
        overlay.style.display = 'none';
    };

    // Auto-resize textarea
    document.querySelectorAll('textarea[data-autoresize]').forEach(function(el) {
        el.addEventListener('input', function () {
            this.style.height = 'auto';
            this.style.height = Math.min(this.scrollHeight, 160) + 'px';
        });
    });
})();
</script>
</body>
</html>
