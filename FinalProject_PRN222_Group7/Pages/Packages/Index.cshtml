@page
@model FinalProject_PRN222_Group7.Pages.Packages.IndexModel
@{
    ViewData["Title"] = "Gói dịch vụ";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Gói dịch vụ</h1>
        <p class="page-subtitle">Nâng cấp gói để tăng giới hạn câu hỏi AI</p>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div style="background:var(--success-muted);border:1px solid rgba(16,185,129,0.25);border-radius:var(--radius);padding:12px 14px;margin-bottom:20px;font-size:0.875rem;color:var(--success)">
        @TempData["Success"]
    </div>
}

@if (Model.IsStudent && Model.UserCurrentPackage != null)
{
    <div class="card" style="margin-bottom:20px">
        <div class="card-header">
            <span class="card-title">Gói hiện tại</span>
            <span class="badge badge-accent">@Model.UserCurrentPackage.Package.Name</span>
        </div>
        <div class="card-body">
            <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px">
                <div>
                    <div style="font-size:0.8rem;color:var(--text-secondary)">
                        Hạn sử dụng: <strong>@Model.UserCurrentPackage.EndDate.ToString("dd/MM/yyyy")</strong>
                    </div>
                    <div style="font-size:0.8rem;color:var(--text-secondary);margin-top:6px">
                        Lượt hỏi AI còn lại: <strong style="color:var(--accent)">@(Model.RemainingQueries == int.MaxValue ? "∞" : Model.RemainingQueries.ToString())</strong>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:16px">
    @foreach (var pkg in Model.Packages)
    {
        <div class="card" style="transition:border-color 0.15s,box-shadow 0.15s" onmouseenter="this.style.borderColor='var(--border-hover)';this.style.boxShadow='var(--shadow)'" onmouseleave="this.style.borderColor='var(--border)';this.style.boxShadow=''">
            <div class="card-body" style="display:flex;flex-direction:column;justify-content:space-between;height:100%;min-height:220px">
                <div>
                    <div style="display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:14px">
                        <div style="width:42px;height:42px;background:var(--accent-muted);border-radius:10px;display:flex;align-items:center;justify-content:center">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--accent)" stroke-width="2" stroke-linecap="round"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 21V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v16"/></svg>
                        </div>
                        <span class="badge badge-muted" style="font-family:var(--font-mono)">@pkg.MonthlyAiQueries lượt/tháng</span>
                    </div>
                    <h3 style="font-size:1rem;font-weight:700;color:var(--text-primary);margin-bottom:6px">@pkg.Name</h3>
                    <p style="font-size:0.8rem;color:var(--text-muted);margin-bottom:14px;min-height:36px">@pkg.Description</p>

                    <div style="display:flex;align-items:center;gap:8px;font-size:0.85rem;color:var(--text-primary);margin-bottom:8px">
                        <span style="font-weight:700">@pkg.Price.ToString("N0") đ</span>
                        <span style="font-size:0.75rem;color:var(--text-muted)">/ tháng</span>
                    </div>
                </div>

                <div style="margin-top:12px;padding-top:12px;border-top:1px solid var(--border)">
                    <form method="post" asp-page-handler="Subscribe" asp-route-packageId="@pkg.Id">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-primary w-full">
                            Chọn gói này
                        </button>
                    </form>
                </div>
            </div>
        </div>
    }
</div>

@if (!Model.Packages.Any())
{
    <div class="card" style="grid-column:1/-1">
        <div class="empty-state">
            <div class="empty-icon">📦</div>
            <div class="empty-title">Chưa có gói dịch vụ</div>
            <div class="empty-hint">Hiện chưa có gói nào được kích hoạt.</div>
        </div>
    </div>
}
