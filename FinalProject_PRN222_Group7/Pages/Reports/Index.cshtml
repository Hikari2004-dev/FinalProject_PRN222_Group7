@page
@model FinalProject_PRN222_Group7.Pages.Reports.IndexModel
@{
    ViewData["Title"] = "Báo cáo & Thống kê";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Báo cáo & Thống kê</h1>
        <p class="page-subtitle">@(User.IsInRole("Admin") || User.IsInRole("Lecturer") ? "Tổng quan hệ thống và phân tích dữ liệu học tập" : "Báo cáo và phân tích dữ liệu học tập cá nhân")</p>
    </div>
    <div style="display:flex;gap:8px">
        <select id="dateRange" class="form-control" style="width:140px" onchange="updateCharts(this.value)">
            <option value="7">7 ngày</option>
            <option value="30" selected>30 ngày</option>
            <option value="90">90 ngày</option>
        </select>
    </div>
</div>

<!-- Stat Cards -->
<div class="stats-grid" style="margin-bottom:28px">
    <div class="stat-card accent">
        <div class="stat-icon accent">
            @if (User.IsInRole("Admin"))
            {
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
            }
            else if (User.IsInRole("Lecturer"))
            {
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
            }
            else
            {
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
            }
        </div>
        <div class="stat-value">@Model.Stats.TotalUsers</div>
        <div class="stat-label">
            @if (User.IsInRole("Admin")) { <text>Tổng người dùng</text> }
            else if (User.IsInRole("Lecturer")) { <text>Học sinh trong lớp</text> }
            else { <text>Lượt hỏi AI</text> }
        </div>
    </div>
    <div class="stat-card success">
        <div class="stat-icon success"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/></svg></div>
        <div class="stat-value">@Model.Stats.TotalDocuments</div>
        <div class="stat-label">
            @if (User.IsInRole("Admin")) { <text>Tài liệu / @Model.Stats.IndexedDocuments indexed</text> }
            else if (User.IsInRole("Lecturer")) { <text>Tài liệu giảng dạy</text> }
            else { <text>Tài liệu học tập</text> }
        </div>
    </div>
    <div class="stat-card info">
        <div class="stat-icon info"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg></div>
        <div class="stat-value">@Model.Stats.TotalSessions</div>
        <div class="stat-label">
            @if (User.IsInRole("Admin")) { <text>Phiên chat AI</text> }
            else if (User.IsInRole("Lecturer")) { <text>Lượt chat môn học</text> }
            else { <text>Phiên chat AI</text> }
        </div>
    </div>
    <div class="stat-card warning">
        <div class="stat-icon warning"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 015.83 1c0 2-3 3-3 3M12 17h.01"/></svg></div>
        <div class="stat-value">@Model.Stats.TotalQuizAttempts</div>
        <div class="stat-label">
            @if (User.IsInRole("Admin")) { <text>Lượt làm quiz</text> }
            else if (User.IsInRole("Lecturer")) { <text>Lượt nộp bài quiz</text> }
            else { <text>Lượt làm quiz</text> }
        </div>
    </div>
</div>

<!-- Charts Grid -->
<div style="display:grid;grid-template-columns:2fr 1fr;gap:20px;margin-bottom:20px">

    <!-- AI Queries Line Chart -->
    <div class="card">
        <div class="card-header">
            <span class="card-title">Lượt hỏi AI theo ngày</span>
        </div>
        <div class="card-body">
            <div class="chart-container" style="height:250px">
                <canvas id="queryLineChart"></canvas>
            </div>
        </div>
    </div>

    <!-- Quiz Score Pie -->
    <div class="card">
        <div class="card-header">
            <span class="card-title">Phân bố điểm quiz</span>
        </div>
        <div class="card-body">
            <div class="chart-container" style="height:250px">
                <canvas id="scoreDistChart"></canvas>
            </div>
        </div>
    </div>
</div>

<div style="display:grid;grid-template-columns: @(User.IsInRole("Admin") || User.IsInRole("Lecturer") ? "1fr 1fr" : "1fr");gap:20px">

    <!-- Course Quiz Bar Chart -->
    <div class="card">
        <div class="card-header">
            <span class="card-title">Điểm quiz TB theo môn</span>
        </div>
        <div class="card-body">
            <div class="chart-container" style="height:220px">
                <canvas id="courseBarChart"></canvas>
            </div>
        </div>
    </div>

    @if (User.IsInRole("Admin") || User.IsInRole("Lecturer"))
    {
        <!-- Revenue + Payments Table -->
        <div class="card">
            <div class="card-header">
                <span class="card-title">Doanh thu</span>
                <span style="font-family:var(--font-mono);font-size:0.9rem;color:var(--success)">@Model.Stats.TotalRevenue.ToString("N0") đ</span>
            </div>
            <div style="overflow:hidden">
                <table>
                    <thead><tr><th>Gói</th><th>Số GD</th><th>Doanh thu</th></tr></thead>
                    <tbody>
                        @foreach (var r in Model.RevenueByPackage)
                        {
                            <tr>
                                <td class="text-primary">@r.PackageName</td>
                                <td style="font-family:var(--font-mono)">@r.Count</td>
                                <td style="font-family:var(--font-mono);color:var(--success)">@r.Total.ToString("N0") đ</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
Chart.defaults.color = '#64748b';
Chart.defaults.borderColor = 'rgba(99,130,185,0.1)';

var queryLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.DailyStats.Select(s => s.Date.ToString("dd/MM"))));
var queryData   = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.DailyStats.Select(s => s.Count)));
var courseNames = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.CourseStats.Select(s => s.CourseName)));
var courseScores = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.CourseStats.Select(s => Math.Round(s.AverageScore, 1))));

// Line chart
new Chart(document.getElementById('queryLineChart'), {
    type: 'line',
    data: {
        labels: queryLabels,
        datasets: [{ label: 'Lượt hỏi', data: queryData, borderColor: '#3b82f6', backgroundColor: 'rgba(59,130,246,0.08)', borderWidth: 2, tension: 0.4, fill: true, pointRadius: 3, pointBackgroundColor: '#3b82f6' }]
    },
    options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } }, scales: { x: { ticks: { maxTicksLimit: 10 } }, y: { beginAtZero: true } } }
});

// Donut chart - score distribution
new Chart(document.getElementById('scoreDistChart'), {
    type: 'doughnut',
    data: {
        labels: ['A (>=90)', 'B (>=70)', 'C (>=50)', 'D (<50)'],
        datasets: [{ data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ScoreDistribution)), backgroundColor: ['#10b981','#3b82f6','#f59e0b','#ef4444'], borderWidth: 0 }]
    },
    options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'bottom', labels: { padding: 12, font: { size: 11 } } } }, cutout: '65%' }
});

// Bar chart
new Chart(document.getElementById('courseBarChart'), {
    type: 'bar',
    data: {
        labels: courseNames,
        datasets: [{ label: 'Điểm TB', data: courseScores, backgroundColor: 'rgba(59,130,246,0.7)', borderRadius: 6 }]
    },
    options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true, max: 100 } } }
});
</script>
}
