@page
@model FinalProject_PRN222_Group7.Pages.Documents.IndexModel
@{
    ViewData["Title"] = "Tài liệu";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Tài liệu</h1>
        <p class="page-subtitle">Quản lý tài liệu học tập đã tải lên</p>
    </div>
    <a href="/Courses" class="btn btn-secondary">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
        Quay lại môn học
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div style="background:var(--success-muted);border:1px solid rgba(16,185,129,0.25);border-radius:var(--radius);padding:12px 14px;margin-bottom:20px;font-size:0.875rem;color:var(--success)">
        @TempData["Success"]
    </div>
}
@if (TempData["Error"] != null)
{
    <div style="background:var(--danger-muted);border:1px solid rgba(239,68,68,0.25);border-radius:var(--radius);padding:12px 14px;margin-bottom:20px;font-size:0.875rem;color:var(--danger)">
        @TempData["Error"]
    </div>
}

<!-- Filters -->
<div class="card" style="margin-bottom:20px">
    <div class="card-body">
        <form method="get" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:12px">
            <div class="form-group" style="margin:0">
                <label class="form-label">Môn học</label>
                <select name="CourseId" class="form-control" onchange="this.form.submit()">
                    <option value="">Tất cả</option>
                    @foreach (var c in Model.Courses)
                    {
                        <option value="@c.Id" selected="@(Model.CourseId == c.Id)">@c.Name (@c.Code)</option>
                    }
                </select>
            </div>
            <div class="form-group" style="margin:0">
                <label class="form-label">Trạng thái</label>
                <select name="Status" class="form-control" onchange="this.form.submit()">
                    <option value="">Tất cả</option>
                    <option value="Uploaded" selected="@(Model.Status == FinalProject_PRN222_Group7.DAL.Entities.DocumentStatus.Uploaded)">Uploaded</option>
                    <option value="Processing" selected="@(Model.Status == FinalProject_PRN222_Group7.DAL.Entities.DocumentStatus.Processing)">Processing</option>
                    <option value="Indexed" selected="@(Model.Status == FinalProject_PRN222_Group7.DAL.Entities.DocumentStatus.Indexed)">Indexed</option>
                    <option value="Failed" selected="@(Model.Status == FinalProject_PRN222_Group7.DAL.Entities.DocumentStatus.Failed)">Failed</option>
                </select>
            </div>
            <div class="form-group" style="margin:0">
                <label class="form-label">Tìm kiếm</label>
                <input type="text" name="Search" class="form-control" placeholder="Tên tài liệu, môn học..." value="@Model.Search" />
            </div>
            <div style="display:flex;align-items:flex-end">
                <button type="submit" class="btn btn-primary" style="height:42px">Lọc</button>
            </div>
        </form>
    </div>
</div>

<!-- List -->
<div class="card">
    <div class="card-header">
        <span class="card-title">Danh sách tài liệu</span>
        <span class="badge badge-muted">@Model.Documents.Count() tài liệu</span>
    </div>
    <div class="table-wrapper">
        <table>
            <thead>
                <tr>
                    <th>Tài liệu</th>
                    <th>Môn học</th>
                    <th>Chương</th>
                    <th>Kích thước</th>
                    <th>Trạng thái</th>
                    <th>Ngày tải lên</th>
                    <th>Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var doc in Model.Documents)
                {
                    <tr>
                        <td>
                            <div style="display:flex;align-items:center;gap:10px;min-width:0">
                                <span style="font-size:1.1rem;flex-shrink:0">📄</span>
                                <div style="min-width:0">
                                    <div style="font-weight:600;color:var(--text-primary);white-space:nowrap;overflow:hidden;text-overflow:ellipsis" title="@doc.OriginalName">@doc.OriginalName</div>
                                    <div style="font-size:0.7rem;color:var(--text-muted);font-family:var(--font-mono)">@doc.FileName</div>
                                </div>
                            </div>
                        </td>
                        <td class="text-primary">@doc.Course?.Name</td>
                        <td>
                            @if (doc.ChapterId.HasValue && Model.ChapterNames.ContainsKey(doc.ChapterId.Value))
                            {
                                <span>@Model.ChapterNames[doc.ChapterId.Value]</span>
                            }
                            else
                            {
                                <span style="color:var(--text-muted)">Chung</span>
                            }
                        </td>
                        <td style="font-family:var(--font-mono);font-size:0.78rem">@FormatSize(doc.FileSizeBytes)</td>
                        <td>
                            @{
                                var (sc, st) = doc.Status switch {
                                    FinalProject_PRN222_Group7.DAL.Entities.DocumentStatus.Indexed => ("badge-success", "Indexed"),
                                    FinalProject_PRN222_Group7.DAL.Entities.DocumentStatus.Processing => ("badge-warning", "Processing"),
                                    FinalProject_PRN222_Group7.DAL.Entities.DocumentStatus.Failed => ("badge-danger", "Failed"),
                                    _ => ("badge-muted", "Uploaded")
                                };
                            }
                            <span class="badge @sc">@st</span>
                            @if (doc.Status == FinalProject_PRN222_Group7.DAL.Entities.DocumentStatus.Failed && !string.IsNullOrEmpty(doc.ErrorMessage))
                            {
                                <div style="font-size:0.7rem;color:var(--danger);margin-top:4px;max-width:220px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis" title="@doc.ErrorMessage">@doc.ErrorMessage</div>
                            }
                        </td>
                        <td style="font-size:0.8rem">@doc.UploadedAt.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>
                            <div style="display:flex;gap:6px;flex-wrap:wrap">
                                <a href="/Documents/Detail/@doc.Id" class="btn btn-secondary btn-sm" style="padding:4px 8px;font-size:0.72rem;height:auto;line-height:1">Chi tiết</a>
                                @if (Model.IsAdmin || (Model.IsLecturer && doc.Course?.LecturerId == Model.CurrentUserId))
                                {
                                    <form method="post" asp-page-handler="Reindex" asp-route-id="@doc.Id" id="reindexForm-@doc.Id" style="display:inline">
                                        @Html.AntiForgeryToken()
                                        <button type="button" class="btn btn-secondary btn-sm" onclick="confirmReindex(@doc.Id, '@Html.Raw(doc.OriginalName.Replace("'", "\\'"))')" style="padding:4px 8px;font-size:0.72rem;height:auto;line-height:1;background:var(--accent-muted);color:var(--accent);border:1px solid rgba(59,130,246,0.25)">Index lại</button>
                                    </form>
                                    <form method="post" asp-page-handler="Delete" asp-route-id="@doc.Id" id="deleteForm-@doc.Id" style="display:inline">
                                        @Html.AntiForgeryToken()
                                        <button type="button" class="btn btn-danger btn-sm" onclick="confirmDelete(@doc.Id, '@Html.Raw(doc.OriginalName.Replace("'", "\\'"))')" style="padding:4px 8px;font-size:0.72rem;height:auto;line-height:1;background:var(--danger-muted);color:var(--danger);border:1px solid rgba(239,68,68,0.25)">Xóa</button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Documents.Any())
                {
                    <tr>
                        <td colspan="7" style="text-align:center;color:var(--text-muted);padding:32px">
                            Không tìm thấy tài liệu nào.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
<script>
    function confirmDelete(id, name) {
        showConfirm(
            'Xóa tài liệu',
            "Bạn có chắc muốn xóa tài liệu \"" + name + "\"?",
            '🗑️',
            () => {
                var form = document.getElementById('deleteForm-' + id);
                if (form) form.submit();
            },
            true
        );
    }

    function confirmReindex(id, name) {
        showConfirm(
            'Lập chỉ mục lại',
            "Bạn có chắc muốn lập chỉ mục lại tài liệu \"" + name + "\"?",
            '🔄',
            () => {
                var form = document.getElementById('reindexForm-' + id);
                if (form) form.submit();
            },
            false
        );
    }
</script>
}

@functions {
    string FormatSize(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes/1024.0:F1} KB";
        return $"{bytes/1024.0/1024.0:F1} MB";
    }
}
